{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stacksjs.org/protocol/1.0-draft/conformance-report.schema.json",
  "title": "Stacks Protocol conformance report",
  "type": "object",
  "additionalProperties": false,
  "required": ["reportVersion", "protocol", "implementation", "execution", "profileClaim", "results", "drivers", "extensions", "exceptions", "generator"],
  "properties": {
    "reportVersion": { "const": "1.0.0-draft.1" },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "catalogRevision", "suiteVersion", "rfcsRevision"],
      "properties": {
        "version": { "const": "1.0-draft" },
        "catalogRevision": { "type": "integer", "minimum": 1 },
        "suiteVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-draft\\.[0-9]+$" },
        "rfcsRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "revision", "repository", "sourceDigest"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
        "sourceDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "completedAt", "runtime", "platform", "ci"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": { "name": { "type": "string" }, "version": { "type": "string" } }
        },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "architecture"],
          "properties": { "os": { "type": "string" }, "architecture": { "type": "string" } }
        },
        "ci": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "runUrl", "artifactUrl"],
          "properties": {
            "provider": { "type": "string" },
            "runUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
            "artifactUrl": { "type": "string", "format": "uri", "pattern": "^https://" }
          }
        }
      }
    },
    "profileClaim": { "type": ["string", "null"], "enum": [null, "Core", "Standard", "Complete"] },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirementId", "status", "fixtureId", "evidenceUrl", "durationMs"],
        "properties": {
          "requirementId": { "type": "string", "pattern": "^(CORE|STD|COMP)-[A-Z]+-[0-9]{2}$" },
          "status": { "enum": ["pass", "fail", "skipped", "unsupported", "exception", "experimental"] },
          "fixtureId": { "type": ["string", "null"] },
          "evidenceUrl": { "type": ["string", "null"], "format": "uri" },
          "durationMs": { "type": "number", "minimum": 0 },
          "notes": { "type": "string" }
        }
      }
    },
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "name", "version", "serviceVersion", "topology", "status", "evidenceUrl"],
        "properties": {
          "category": { "enum": ["database", "queue", "cache", "storage", "mail", "realtime", "deploy"] },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "serviceVersion": { "type": ["string", "null"] },
          "topology": { "type": "string" },
          "status": { "enum": ["supported", "partial", "experimental", "unsupported"] },
          "evidenceUrl": { "type": ["string", "null"], "format": "uri" },
          "prerequisites": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidenceUrl"],
        "properties": {
          "id": { "type": "string", "pattern": "^EXT-[A-Z0-9]+-[0-9]{2}$" },
          "status": { "enum": ["pass", "fail", "skipped", "unsupported", "exception", "experimental"] },
          "evidenceUrl": { "type": ["string", "null"], "format": "uri" },
          "notes": { "type": "string" }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirementId", "rfc", "expiresAt", "rationale"],
        "properties": {
          "requirementId": { "type": "string" },
          "rfc": { "type": "string", "format": "uri", "pattern": "^https://" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "rationale": { "type": "string", "minLength": 10 }
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "revision"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    }
  }
}

