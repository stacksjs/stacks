{
  "name": "stacks",
  "type": "module",
  "version": "0.70.52",
  "private": true,
  "description": "Your project description",
  "author": "your-name <your-email>",
  "contributors": [
    "Chris Breuer <chris@stacksjs.org>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "scripts": {
    "build:reset": "rm -rf node_modules && pantry install && ./buddy generate:types && ./buddy lint:fix && cd storage/framework && bun run build && cd ../../",
    "buddy": "bun ./storage/framework/core/buddy/src/cli.ts",
    "stacks": "./buddy",
    "setup": "./bootstrap",
    "fresh": "./buddy fresh",
    "clean": "./buddy clean",
    "upgrade": "./buddy upgrade",
    "dev": "./buddy dev",
    "development": "./buddy dev",
    "build": "./buddy build",
    "prod": "./buddy build",
    "deploy": "./buddy deploy",
    "lint": "./buddy lint",
    "lint:fix": "./buddy lint:fix",
    "format": "./buddy format",
    "format:check": "./buddy format:check",
    "serve": "./buddy serve",
    "make": "./buddy make",
    "make:component": "./buddy make:component",
    "make:function": "./buddy make:function",
    "make:database": "./buddy make:migration",
    "make:migration": "./buddy make:migration",
    "make:notification": "./buddy make:notification",
    "make:factory": "./buddy make:factory",
    "make:lang": "./buddy make:lang",
    "make:stack": "./buddy make:stack",
    "key:generate": "./buddy key:generate",
    "commit": "./buddy commit",
    "release": "./buddy release",
    "release:patch": "./buddy release --bump patch",
    "release:minor": "./buddy release --bump minor",
    "release:major": "./buddy release --bump major",
    "changelog": "./buddy changelog",
    "generate": "./buddy generate",
    "typecheck": "bun x --bun tsc --build tsconfig.framework.json --pretty false",
    "typecheck:app": "bun x --bun tsc --build tsconfig.json --pretty false",
    "typecheck:clean": "bun x --bun tsc --build --clean tsconfig.framework.json tsconfig.json",
    "types:check": "bun run typecheck",
    "types:fix": "./buddy types:fix",
    "test": "./buddy test",
    "test:ui": "./buddy test:ui",
    "test:coverage": "./buddy test:coverage",
    "test:types": "./buddy test:types",
    "docs:buddy": "bun scripts/docs/buddy-commands.ts --write",
    "docs:buddy:check": "bun scripts/docs/buddy-commands.ts --check",
    "protocol:sync": "bun scripts/protocol/sync-suite.ts --write",
    "protocol:check": "bun scripts/protocol/sync-suite.ts --check",
    "protocol:conformance": "bun scripts/protocol/run-conformance.ts",
    "protocol:manifest": "bun scripts/protocol/source-manifest.ts --write",
    "protocol:manifest:check": "bun scripts/protocol/source-manifest.ts --check",
    "protocol:release": "bun scripts/protocol/release-manifest.ts --write",
    "protocol:release:check": "bun scripts/protocol/release-manifest.ts --check",
    "protocol:drivers": "bun scripts/protocol/driver-registry.ts --write",
    "protocol:drivers:check": "bun scripts/protocol/driver-registry.ts --check",
    "protocol:desktop": "bun scripts/protocol/desktop-support.ts --write",
    "protocol:desktop:check": "bun scripts/protocol/desktop-support.ts --check",
    "bud": "./buddy",
    "stx": "./buddy"
  },
  "system": {
    "bun": "^1.3.0",
    "git": "^2.47.0",
    "sqlite": "^3.47.2",
    "craft": "^0.0.19"
  },
  "dependencies": {
    "stacks": "workspace:*"
  },
  "workspaces": [
    "storage/framework",
    "storage/framework/libs/*",
    "storage/framework/views/*",
    "storage/framework/core",
    "storage/framework/core/*"
  ],
  "catalog": {
    "@stacksjs/clapp": "^0.2.12",
    "@stacksjs/components": "^0.2.82",
    "@stacksjs/gitlint": "^0.1.5",
    "@stacksjs/stx": "^0.2.99",
    "@stacksjs/ts-cloud": "^0.7.49",
    "better-dx": "^0.2.17",
    "bun-git-hooks": "^0.3.2",
    "bun-query-builder": "^0.1.56",
    "pickier": "^0.1.35",
    "redis": "^5.12.1",
    "web-ext": "^10.5.0"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bun x --bun pickier lint --fix"
      }
    },
    "commit-msg": "bun x gitlint --edit .git/COMMIT_EDITMSG"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
