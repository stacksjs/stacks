#!/usr/bin/env bash

set -u

script_dir="$(cd "$(dirname "$0")" && pwd)"
roots=(
  "$script_dir/../libs/components"
  "$script_dir/../libs/functions"
)

package_files=()
for root in "${roots[@]}"; do
  if [ ! -d "$root" ]; then
    continue
  fi

  while IFS= read -r package_file; do
    package_files+=("$package_file")
  done < <(find "$root" -path '*/node_modules' -prune -o -name package.json -print)
done

if [ ${#package_files[@]} -eq 0 ]; then
  echo "No dummy libraries found"
  exit 0
fi

for package_file in "${package_files[@]}"; do
  dir="$(dirname "$package_file")"

  echo ""
  echo "🏗️  Releasing dummy library"
  echo "📦 $dir"

  if grep -q '"private"[[:space:]]*:[[:space:]]*true' "$package_file"; then
    echo "↪ Skipping private package"
    continue
  fi

  (
    cd "$dir"
    bun publish --access public
  )

  status=$?
  if [ $status -ne 0 ]; then
    echo "⚠️  Dummy library publish skipped after failure ($status): $dir"
    continue
  fi

  echo "✅ Dummy library published"
done

exit 0
