{
  "name": "@stacksjs/buddy",
  "type": "module",
  "sideEffects": false,
  "version": "0.70.163",
  "description": "Meet Buddy. The Stacks runtime.",
  "author": "Chris Breuer",
  "contributors": [
    "Chris Breuer <chris@stacksjs.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks/tree/main/stacks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git",
    "directory": "./storage/framework/core/buddy"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "keywords": [
    "stacks",
    "buddy",
    "runtime",
    "component",
    "composables",
    "functions",
    "headless",
    "api",
    "ssg",
    "pwa",
    "modern",
    "library",
    "stx",
    "web components",
    "typescript",
    "javascript",
    "starter kit"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "development": "./src/cli.ts",
      "bun": "./dist/cli.js",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    },
    "./*": {
      "development": "./src/*",
      "bun": "./dist/*",
      "import": "./dist/*",
      "default": "./dist/*"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "stacks": "dist/cli.js",
    "buddy": "dist/cli.js",
    "bud": "dist/cli.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "buddy": "bunx --bun ./src/cli.ts",
    "build": "bun build.ts",
    "compile": "bun build ./src/cli.ts --compile --minify --sourcemap --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile dist/buddy",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64",
    "compile:linux-x64": "bun build ./src/cli.ts --compile --minify --target=bun-linux-x64 --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile bin/buddy-linux-x64",
    "compile:linux-arm64": "bun build ./src/cli.ts --compile --minify --target=bun-linux-arm64 --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile bin/buddy-linux-arm64",
    "compile:windows-x64": "bun build ./src/cli.ts --compile --minify --target=bun-windows-x64 --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile bin/buddy-windows-x64.exe",
    "compile:darwin-x64": "bun build ./src/cli.ts --compile --minify --target=bun-darwin-x64 --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile bin/buddy-darwin-x64",
    "compile:darwin-arm64": "bun build ./src/cli.ts --compile --minify --target=bun-darwin-arm64 --external=localtunnels/cloud --external=bun-queue --external=@stacksjs/bun-queue --outfile bin/buddy-darwin-arm64",
    "typecheck": "bun tsc --noEmit",
    "zip:all": "bun run zip:linux-x64 && bun run zip:linux-arm64 && bun run zip:windows-x64 && bun run zip:darwin-x64 && bun run zip:darwin-arm64",
    "zip:linux-x64": "zip -j bin/buddy-linux-x64.zip bin/buddy-linux-x64",
    "zip:linux-arm64": "zip -j bin/buddy-linux-arm64.zip bin/buddy-linux-arm64",
    "zip:windows-x64": "zip -j bin/buddy-windows-x64.zip bin/buddy-windows-x64.exe",
    "zip:darwin-x64": "zip -j bin/buddy-darwin-x64.zip bin/buddy-darwin-x64",
    "zip:darwin-arm64": "zip -j bin/buddy-darwin-arm64.zip bin/buddy-darwin-arm64",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@stacksjs/actions": "workspace:*",
    "@stacksjs/ai": "workspace:*",
    "@stacksjs/alias": "workspace:*",
    "@stacksjs/arrays": "workspace:*",
    "@stacksjs/auth": "workspace:*",
    "@stacksjs/build": "workspace:*",
    "@stacksjs/cache": "workspace:*",
    "@stacksjs/cli": "workspace:*",
    "@stacksjs/clapp": "catalog:",
    "@stacksjs/cloud": "workspace:*",
    "@stacksjs/collections": "workspace:*",
    "@stacksjs/config": "workspace:*",
    "@stacksjs/database": "workspace:*",
    "@stacksjs/desktop": "workspace:*",
    "@stacksjs/dns": "workspace:*",
    "@stacksjs/email": "workspace:*",
    "@stacksjs/enums": "workspace:*",
    "@stacksjs/error-handling": "workspace:*",
    "@stacksjs/events": "workspace:*",
    "@stacksjs/git": "workspace:*",
    "@stacksjs/gitit": "^0.2.5",
    "@stacksjs/health": "workspace:*",
    "@stacksjs/dnsx": "^0.2.3",
    "@stacksjs/httx": "^0.1.10",
    "@stacksjs/lint": "workspace:*",
    "@stacksjs/logging": "workspace:*",
    "@stacksjs/notifications": "workspace:*",
    "@stacksjs/objects": "workspace:*",
    "@stacksjs/orm": "workspace:*",
    "@stacksjs/path": "workspace:*",
    "@stacksjs/payments": "workspace:*",
    "@stacksjs/realtime": "workspace:*",
    "@stacksjs/router": "workspace:*",
    "@stacksjs/rpx": "^0.11.33",
    "@stacksjs/search-engine": "workspace:*",
    "@stacksjs/security": "workspace:*",
    "@stacksjs/server": "workspace:*",
    "@stacksjs/storage": "workspace:*",
    "@stacksjs/strings": "workspace:*",
    "@stacksjs/testing": "workspace:*",
    "@stacksjs/tunnel": "workspace:*",
    "@stacksjs/types": "workspace:*",
    "@stacksjs/ui": "workspace:*",
    "@stacksjs/utils": "workspace:*",
    "@stacksjs/validation": "workspace:*",
    "@stacksjs/ts-cloud": "catalog:"
  },
  "devDependencies": {
    "better-dx": "catalog:"
  },
  "web-types": "./web-types.json"
}
