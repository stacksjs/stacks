  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "bun tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@stacksjs/cli": "workspace:*",
    "@stacksjs/config": "workspace:*",
    "better-dx": "^0.2.12",
    "@stacksjs/ts-faker": "^0.1.7"
  },
  "sideEffects": false
