{
  "compilerOptions": {
    // `baseUrl` was deprecated in TS 6.0 and will be removed in TS 7.0.
    // We rely on TypeScript's automatic `paths`-relative resolution
    // (introduced in 4.1) so the path mappings keep working — they're
    // resolved relative to this file's directory.
    "target": "esnext",
    // Include DOM types because several core packages re-export from
    // `@stacksjs/browser` (utils, composables, ui, dashboard) and
    // those modules legitimately reference `window`, `document`,
    // `HTMLElement`, etc. Pure server packages can still opt to a
    // narrower lib via their own tsconfig if they want stricter
    // browser-API isolation.
    "lib": ["esnext", "dom", "dom.iterable"],
    "moduleDetection": "force",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["../../../*"],
      "@stacksjs/*": ["./*/src"],
      "*": ["../../../pantry/*"]
    },
    "resolveJsonModule": true,
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedDeclarations": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  }
}
