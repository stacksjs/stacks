{
  "name": "@stacksjs/slug",
  "type": "module",
  "version": "0.70.45",
  "description": "The Stacks slug functionality.",
  "author": "Chris Breuer",
  "contributors": [
    "Chris Breuer <chris@stacksjs.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks/tree/main/storage/framework/core/database#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git",
    "directory": "./storage/framework/core/slug"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "keywords": [
    "slugs",
    "models",
    "urls",
    "stacks"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "bun": "./src/*",
      "import": "./dist/*"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@stacksjs/cli": "workspace:*0.70.45",
    "@stacksjs/database": "workspace:*0.70.45",
    "better-dx": "^0.2.12",
    "@stacksjs/path": "workspace:*0.70.45",
    "@stacksjs/strings": "workspace:*0.70.45",
    "@stacksjs/utils": "workspace:*0.70.45"
  },
  "sideEffects": false
}
