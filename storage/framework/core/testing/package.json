{
  "name": "@stacksjs/testing",
  "type": "module",
  "sideEffects": false,
  "version": "0.70.87",
  "description": "The Stacks way of testing.",
  "author": "Chris Breuer",
  "contributors": [
    "Chris Breuer <chris@stacksjs.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks/tree/main/storage/framework/core/testing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git",
    "directory": "./storage/framework/core/testing"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "keywords": [
    "tests",
    "unit",
    "feature",
    "e2e",
    "testing",
    "utilities",
    "functions",
    "playwright",
    "stacks"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "development": "./src/database.ts",
      "bun": "./dist/database.js",
      "import": "./dist/database.js",
      "default": "./dist/database.js"
    },
    "./dynamodb": {
      "types": "./dist/dynamodb.d.ts",
      "development": "./src/dynamodb.ts",
      "bun": "./dist/dynamodb.js",
      "import": "./dist/dynamodb.js",
      "default": "./dist/dynamodb.js"
    },
    "./*": {
      "development": "./src/*",
      "bun": "./dist/*",
      "import": "./dist/*",
      "default": "./dist/*"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@stacksjs/ts-cloud": "^0.7.17"
  },
  "devDependencies": {
    "@stacksjs/config": "workspace:*",
    "@stacksjs/database": "workspace:*",
    "better-dx": "^0.2.16"
  }
}
