{
  "name": "@stacksjs/ui",
  "type": "module",
  "version": "0.70.87",
  "description": "The Stacks UI engine.",
  "author": "Chris Breuer",
  "contributors": [
    "Chris Breuer <chris@stacksjs.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks/tree/main/storage/framework/core/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git",
    "directory": "./storage/framework/core/ui"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "keywords": [
    "css",
    "atomic",
    "ui",
    "engine",
    "styles",
    "stacks",
    "crosswind",
    "tailwind"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "development": "./src/components.ts",
      "bun": "./dist/components.js",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@cwcss/crosswind": "^0.2.6",
    "@stacksjs/components": "^0.2.82"
  },
  "devDependencies": {
    "@stacksjs/build": "workspace:*",
    "@stacksjs/config": "workspace:*",
    "better-dx": "^0.2.16",
    "@stacksjs/router": "workspace:*"
  }
