{
  "name": "@stacksjs/orm",
  "type": "module",
  "sideEffects": false,
  "version": "0.70.87",
  "description": "The Stacks ORM integration",
  "author": "Chris Breuer",
  "contributors": [
    "Chris Breuer <chris@stacksjs.com>"
  ],
  "license": "MIT",
  "funding": "https://github.com/sponsors/chrisbbreuer",
  "homepage": "https://github.com/stacksjs/stacks/tree/main/storage/framework/core/orm#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stacks.git",
    "directory": "./storage/framework/core/orm"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stacks/issues"
  },
  "keywords": [
    "stacks",
    "orm",
    "bun"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "development": "./src/index.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./traits/*": {
      "types": "./dist/src/traits/*.d.ts",
      "development": "./src/traits/*.ts",
      "bun": "./dist/traits/*.js",
      "import": "./dist/traits/*.js",
      "default": "./dist/traits/*.js"
    },
    "./*": {
      "development": "./src/*",
      "bun": "./dist/*",
      "import": "./dist/*",
      "default": "./dist/*"
    }
  },
  "module": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@stacksjs/ts-validation": "^0.5.0",
    "bun-query-builder": "^0.1.47"
  },
  "devDependencies": {
    "@stacksjs/config": "workspace:*",
    "better-dx": "^0.2.16",
    "@stacksjs/query-builder": "workspace:*",
    "@stacksjs/types": "workspace:*"
  }
}
