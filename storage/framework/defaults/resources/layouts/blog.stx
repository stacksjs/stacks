<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title || 'Blog' }} | Stacks Blog</title>
  <meta name="description" content="{{ description || 'A modern blog powered by Stacks' }}">
  <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/api/blog/feed.xml">
  <style>
    @font-face {
      font-family: 'Campmate Script';
      src: url('/assets/fonts/nps/CampmateScript-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Sequoia Sans';
      src: url('/assets/fonts/nps/SequoiaSans-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Switchback';
      src: url('/assets/fonts/nps/Switchback-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #f7f0e3;
      --color-bg-secondary: #fffaf0;
      --color-bg-muted: #efe4d1;
      --color-text: #273128;
      --color-text-secondary: #56624f;
      --color-primary: #2f5d3a;
      --color-primary-hover: #24472d;
      --color-accent: #b7792d;
      --color-accent-soft: #f5dfb8;
      --color-border: #d5c5a6;
      --color-shadow: 0 14px 32px -24px rgba(53, 39, 19, 0.55);
      --font-display: 'Campmate Script', 'Sequoia Sans', system-ui, sans-serif;
      --font-sans: 'Sequoia Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-serif: 'Switchback', Georgia, serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --color-bg: #172017;
        --color-bg-secondary: #202a1f;
        --color-bg-muted: #263323;
        --color-text: #f3ead7;
        --color-text-secondary: #c9bea6;
        --color-border: #4b5a3e;
        --color-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.9);
      }
    }

    body {
      position: relative;
      font-family: var(--font-sans);
      background: var(--color-bg);
      background-image: linear-gradient(180deg, rgba(255, 250, 240, 0.7), rgba(239, 228, 209, 0.48));
      color: var(--color-text);
      line-height: 1.6;
      min-height: 100vh;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: url('/assets/images/topography.svg');
      background-size: 520px 520px;
      background-repeat: repeat;
      opacity: 0.025;
      z-index: 0;
    }
    body > * {
      position: relative;
      z-index: 1;
    }

    @media (prefers-color-scheme: dark) {
      body {
        background-image: linear-gradient(180deg, rgba(31, 42, 31, 0.95), rgba(23, 32, 23, 0.95));
      }
    }

    a { color: var(--color-primary); text-decoration: none; }
    a:hover { color: var(--color-primary-hover); }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .container-narrow {
      max-width: 768px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Header */
    .blog-header {
      border-bottom: 3px solid var(--color-accent);
      padding: 1.5rem 0;
      position: sticky;
      top: 0;
      background: var(--color-primary);
      z-index: 100;
      box-shadow: 0 6px 18px -16px rgba(37, 29, 14, 0.8);
    }

    .blog-header .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .blog-logo {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 750;
      color: var(--color-bg-secondary);
    }

    .blog-nav {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .blog-nav a {
      color: #efe4d1;
      font-weight: 500;
      font-size: 0.9375rem;
      transition: color 0.2s;
    }

    .blog-nav a:hover { color: var(--color-accent-soft); }

    .subscribe-btn {
      background: var(--color-accent);
      color: white !important;
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
      font-weight: 500;
      transition: background 0.2s;
    }

    .subscribe-btn:hover { background: #96621f; }

    /* Main content */
    main { padding: 3rem 0; min-height: calc(100vh - 200px); }

    /* Footer */
    .blog-footer {
      border-top: 3px solid var(--color-accent);
      padding: 3rem 0;
      background: var(--color-primary);
    }

    .blog-footer .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-links a {
      color: var(--color-accent-soft);
      font-size: 0.875rem;
    }

    .footer-copy {
      color: #efe4d1;
      font-size: 0.875rem;
    }

    /* Utility classes */
    .text-secondary { color: var(--color-text-secondary); }
    .text-sm { font-size: 0.875rem; }
    .mt-2 { margin-top: 0.5rem; }
    .mt-4 { margin-top: 1rem; }
    .mt-8 { margin-top: 2rem; }
    .mb-4 { margin-bottom: 1rem; }
    .mb-8 { margin-bottom: 2rem; }

    @media (max-width: 640px) {
      .blog-header { padding: 0.75rem 0; }
      .blog-header .container { gap: 0.75rem; padding: 0 1rem; }
      .blog-logo { font-size: 1rem; white-space: nowrap; }
      .blog-nav { gap: 0.75rem; }
      .blog-nav a { font-size: 0.75rem; }
      .subscribe-btn { padding: 0.4rem 0.65rem; }
    }
  </style>
</head>
<body>
  <header class="blog-header">
    <div class="container">
      <a href="/blog" class="blog-logo">Stacks Blog</a>
      <nav class="blog-nav">
        <a href="/blog">Articles</a>
        <a href="/blog/categories">Categories</a>
        <a href="/api/blog/feed.xml">RSS</a>
        <a href="/blog#newsletter" class="subscribe-btn">Subscribe</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="blog-footer">
    <div class="container">
      <div class="footer-links">
        <a href="/blog">Blog</a>
        <a href="/api/blog/sitemap.xml">Sitemap</a>
        <a href="/api/blog/feed.xml">RSS Feed</a>
      </div>
      <p class="footer-copy">Powered by Stacks</p>
    </div>
  </footer>
</body>
</html>
