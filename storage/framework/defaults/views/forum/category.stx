<ForumLayout :route="routeType">
  <div class="grid gap-8 grid-cols-1 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <ForumBreadcrumb :items="breadcrumbItems" />

      <div class="mb-6">
        <div class="flex items-center justify-between px-4 py-3 bg-gray-100 rounded-t-md">
          <div>
            <h1 class="font-bold text-xl">{{ categoryTitle }}</h1>
            <p class="mt-1 text-gray-600 text-sm">{{ categoryDescription }}</p>
          </div>

          <div>
            <a href="/forum/new-topic" class="px-4 py-2 text-white bg-primary rounded-md hover:opacity-90">New Topic</a>
          </div>
        </div>
      </div>

      <ForumTopicList :title="listTitle">
        @foreach (topic in topics)
          <ForumTopicItem
            :key="topic.id"
            :title="topic.title"
            :link="topic.link"
            :authorName="topic.authorName"
            :authorAvatar="topic.authorAvatar"
            :createdAt="topic.createdAt"
            :viewCount="topic.viewCount"
            :replyCount="topic.replyCount"
            :likeCount="topic.likeCount"
            :category="topic.category"
            :categoryLink="topic.categoryLink"
            :excerpt="topic.excerpt || ''"
            :isPinned="!!topic.isPinned"
            :isSolved="!!topic.isSolved"
            :lastReplyAuthorName="topic.lastReplyAuthorName || ''"
            :lastReplyAuthorAvatar="topic.lastReplyAuthorAvatar || ''"
            :lastReplyAt="topic.lastReplyAt || ''"
          />
        @endforeach
      </ForumTopicList>

      <ForumPagination :currentPage="1" :totalPages="5" />
    </div>

    <div class="lg:col-span-1">
      <ForumSidebar
        :stats="{
