@extends('layouts/default')

@section('content')
<script server>
useSeoMeta({ title: 'Deployments · App · Dashboard' })

// Data available when full dev server runs (buddy dev)
let deployments = []

function statusVariant(s) {
  s = String(s || '').toLowerCase()
  if (['active', 'success', 'healthy', 'completed', 'running', 'published'].includes(s)) return 'success'
  if (['pending', 'scheduled', 'warning', 'draft'].includes(s)) return 'warning'
  if (['failed', 'error', 'inactive', 'cancelled'].includes(s)) return 'danger'
  if (['processing', 'info'].includes(s)) return 'primary'
  return 'default'
}
</script>
<div class="p-6 space-y-6">

  <PageHeader title="Deployments" description="Monitor and manage deployments">
    <Button variant="primary" size="sm">Deploy Now</Button>
  </PageHeader>

    @if (deployments.length > 0)
    <div class="bg-white dark:bg-neutral-800/90 border border-black/5 rounded-xl dark:border-white/5">
      <DataTable
        :columns="[
          { key: 'id', label: 'Deployment' },
          { key: 'status', label: 'Status' },
          { key: 'branch', label: 'Branch' },
          { key: 'commit', label: 'Commit' },
          { key: 'author', label: 'Author' },
          { key: 'duration', label: 'Duration' },
          { key: 'time', label: 'Time' }
        ]"
        :data="deployments"
        emptyTitle="No deployments yet"
        emptyDescription="Deploy your application using buddy deploy to see deployment history."
        emptyIcon="i-hugeicons-rocket-01"
      >
        @foreach (deployments as deploy)
          <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.02] transition-colors">
            <td class="px-4 py-3 font-medium text-[13px] text-neutral-900 dark:text-white">{{ deploy.id }}</td>
            <td class="px-4 py-3">
              <Badge variant="{{ statusVariant(deploy.status) }}" size="sm" dot>{{ deploy.status }}</Badge>
            </td>
            <td class="px-4 py-3"><code class="px-1.5 py-0.5 font-mono text-xs bg-neutral-100 dark:bg-neutral-700 rounded">{{ deploy.branch }}</code></td>
            <td class="px-4 py-3"><code class="px-1.5 py-0.5 font-mono text-xs bg-neutral-100 dark:bg-neutral-700 rounded">{{ deploy.commit }}</code></td>
            <td class="px-4 py-3 text-[13px] text-neutral-600 dark:text-neutral-300">{{ deploy.author }}</td>
            <td class="px-4 py-3 font-mono text-[12px] text-neutral-500 dark:text-neutral-400">{{ deploy.duration }}</td>
            <td class="px-4 py-3 text-[12px] text-neutral-500 dark:text-neutral-400">{{ deploy.time }}</td>
          </tr>
        @endforeach
      </DataTable>
    </div>
    @else
    <div class="flex flex-col items-center justify-center px-4 py-16">
      <div class="flex items-center justify-center mb-4 h-16 w-16 bg-neutral-100 dark:bg-neutral-800 rounded-full">
        <span class="text-2xl text-neutral-400">&#x1F680;</span>
      </div>
      <h3 class="mb-2 font-semibold text-lg text-neutral-900 dark:text-white">No deployments yet</h3>
      <p class="max-w-sm text-center text-neutral-500 text-sm dark:text-neutral-400">Deploy your application using buddy deploy to see deployment history.</p>
    </div>
    @endif
</div>
@endsection
