@extends('layouts/default')

@section('content')
<script server>
let modelSlug = typeof model !== 'undefined' ? model : 'unknown'
let tableName = modelSlug.replace(/-/g, '_').replace(/[^a-z0-9_]/gi, '') + 's'
let modelName = modelSlug.split('-').map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(' ')

let items = []
let columns = []
let error = null
let totalCount = 0
let recentCount = 0
let statusBreakdown = {}
let statusKeys = []

try {
  const orm = await import('@stacksjs/orm')
  const pascalName = modelSlug.split('-').map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join('')
  const ModelClass = orm[pascalName]
  if (ModelClass) {
    const allItems = await ModelClass.orderBy('created_at', 'desc').get()
    totalCount = allItems.length
    if (allItems.length > 0) {
      const first = allItems[0]
      const attrs = first.getAttributes ? first.getAttributes() : {}
      columns = Object.keys(attrs).filter(k => !['password', 'token', 'secret'].includes(k))
      items = allItems.map(item => {
        const row = {}
        columns.forEach(col => { row[col] = String(item.get(col) || '') })
        return row
      })
      const now = new Date()
      recentCount = allItems.filter(item => {
        const d = new Date(String(item.get('created_at') || ''))
        return (now.getTime() - d.getTime()) < 7 * 24 * 60 * 60 * 1000
      }).length
      allItems.forEach(item => {
        const s = String(item.get('status') || 'N/A')
        statusBreakdown[s] = (statusBreakdown[s] || 0) + 1
      })
      statusKeys = Object.keys(statusBreakdown)
    }
  } else {
    error = 'Model not found: ' + pascalName
  }
} catch (e) {
  error = 'DB not seeded'
}

function statusVariant(s) {
  s = String(s || '').toLowerCase()
  if (['active', 'success', 'healthy', 'completed', 'running', 'published'].includes(s)) return 'success'
  if (['pending', 'scheduled', 'warning', 'draft'].includes(s)) return 'warning'
  if (['failed', 'error', 'inactive', 'cancelled'].includes(s)) return 'danger'
  if (['processing', 'info'].includes(s)) return 'primary'
  return 'default'
}
</script>
  <div ref="pageRoot" class="p-6">
    <div class="mb-4">
      <a href="/app#data-dashboard" class="flex gap-1 items-center text-blue-600 text-sm dark:text-blue-400 hover:underline">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Back to Dashboard
      </a>
    </div>
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="font-bold text-2xl text-gray-900 dark:text-white">{{ modelName }}</h1>
        <p class="mt-1 text-gray-500 text-sm dark:text-neutral-400">
          @if(error)
            Table "{{ tableName }}" not found or error occurred
          @else
            {{ totalCount }} records in {{ tableName }}
          @endif
        </p>
      </div>
      <div class="flex gap-3">
        <Button variant="outline" size="sm">Export</Button>
        <Button variant="primary" size="sm">Add New</Button>
      </div>
    </div>

    <!-- Error State -->
      <div class="p-6 bg-red-50 dark:bg-red-900/20 border border-red-200 rounded-xl dark:border-red-800">
        <div class="flex gap-3 items-center">
          <div class="flex items-center justify-center h-10 w-10 bg-red-100 dark:bg-red-900/30 rounded-full">
