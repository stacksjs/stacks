let teams = []
let totalTeams = 0
let totalMembers = 0
let activeProjects = 0

try {
  // Team table does not exist yet -- leave empty
  teams = []
  totalTeams = 0
  totalMembers = 0
  activeProjects = 0
} catch (e) {
  // DB not seeded
}
