        </div>
        <div class="text-neutral-500 dark:text-neutral-400 text-[13px] mb-3">Team Lead: {{ team.lead }}</div>
        <div class="grid grid-cols-2 gap-4 mt-4">
          <div>
            <div class="text-2xl font-semibold text-neutral-900 dark:text-white">{{ team.members }}</div>
            <div class="text-[12px] text-neutral-500 dark:text-neutral-400">Members</div>
          </div>
          <div>
            <div class="text-2xl font-semibold text-neutral-900 dark:text-white">{{ team.projects }}</div>
            <div class="text-[12px] text-neutral-500 dark:text-neutral-400">Projects</div>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-neutral-200/60 dark:border-white/5 flex gap-2">
          <Button variant="outline" size="xs" class="flex-1">View</Button>
          <Button variant="ghost" size="xs">Edit</Button>
        </div>
      </Card>
    @endforeach
  </div>
  @else
