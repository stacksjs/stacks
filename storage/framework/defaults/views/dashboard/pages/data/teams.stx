<DashboardLayout>
<div class="p-6 space-y-6">

  <PageHeader title="Teams" description="Manage team organization">
    <template #actions>
      <Button variant="primary">
        <div class="i-hugeicons-plus-sign h-4 w-4"></div>
        Create Team
      </Button>
