<script server>
// Dashboard stx serve doesn't auto-import SEO helpers — guard so a missing global doesn't crash the page render.
if (typeof useSeoMeta === 'function') useSeoMeta({ title: 'Comments · Content · Dashboard' })
/**
 * Comments Moderation Page
 */

// Data available when full dev server runs (buddy dev)
let comments = []
let stats = { total: 0, pending: 0, approved: 0, spam: 0 }

function statusVariant(s) {
  s = String(s || '').toLowerCase()
  if (s === 'approved') return 'success'
  if (s === 'pending') return 'warning'
  if (s === 'spam') return 'danger'
  return 'default'
}
</script>

