      <div class="mx-auto h-12 w-12 text-red-500 i-hugeicons-waste"></div>
      <h3 class="mt-4 font-semibold text-gray-900 text-lg dark:text-white">Delete Comment</h3>
      <p class="mt-2 text-gray-500 dark:text-neutral-400">Are you sure you want to delete this comment? This action cannot be undone.</p>
    </div>
    <div class="flex gap-3 items-center justify-center mt-6">
      <Button id="cancelDeleteBtn" variant="ghost">Cancel</Button>
      <Button id="confirmDeleteBtn" variant="danger">Delete</Button>
