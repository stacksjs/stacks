<!-- Toast -->
<div id="toast" class="bottom-4 fixed right-4 z-50 opacity-0 duration-300 transition-all transform translate-y-full">
  <div class="px-4 py-3 text-white dark:text-neutral-900 bg-gray-900 dark:bg-white rounded-lg shadow-lg">
    <span id="toastMessage">Action completed!</span>
  </div>
</div>
</div>

<script client>
const _root = useRef('pageRoot')
const API_BASE = 'http://localhost:' + (process.env.PORT_API || '3008') + '/cms'
let deleteCommentId = null

let viewModal, deleteModal

function closeModals() {
  viewModal.style.display = 'none'
  deleteModal.style.display = 'none'
}

function showToast(message) {
  const el = _root.current
  if (!el) return
  const toast = el.querySelector('#toast')
  el.querySelector('#toastMessage').textContent = message
  toast.style.transform = 'translateY(0)'
  toast.style.opacity = '1'
  useTimeout(() => {
    toast.style.transform = 'translateY(100%)'
    toast.style.opacity = '0'
  }, 3000)
}

function updateStatus(id, status) {
  fetch(`${API_BASE}/comments/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  })
    .then(r => r.json())
    .then(() => {
      showToast(`Comment ${status}!`)
      useTimeout(() => location.reload(), 1000)
    })
    .catch(() => showToast('Failed to update comment'))
}

function deleteComment() {
  if (!deleteCommentId) return
  fetch(`${API_BASE}/comments/${deleteCommentId}`, { method: 'DELETE' })
    .then(r => r.json())
    .then(() => {
      showToast('Comment deleted!')
      closeModals()
      useTimeout(() => location.reload(), 1000)
    })
    .catch(() => showToast('Failed to delete comment'))
}

function filterComments(status) {
  const el = _root.current
  if (!el) return
  el.querySelectorAll('.comment-row').forEach(row => {
    row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none'
  })
  el.querySelectorAll('[data-filter]').forEach(tab => {
    const isActive = tab.dataset.filter === status
    tab.classList.toggle('text-white', isActive)
    tab.classList.toggle('bg-blue-600', isActive)
    tab.classList.toggle('text-gray-500', !isActive)
  })
}

onMount(function() {
  const el = _root.current
  if (!el) return

  viewModal = el.querySelector('#viewModal')
  deleteModal = el.querySelector('#deleteModal')

  // Event bindings
  el.querySelector('#closeViewModal').onclick = closeModals
  el.querySelector('#cancelDeleteBtn').onclick = closeModals
  el.querySelector('#confirmDeleteBtn').onclick = deleteComment

  el.querySelectorAll('[data-filter]').forEach(tab => {
    tab.onclick = function() { filterComments(this.dataset.filter) }
  })

  el.querySelectorAll('[data-action="approve"]').forEach(btn => {
    btn.onclick = function() { updateStatus(this.dataset.id, 'approved') }
  })

  el.querySelectorAll('[data-action="spam"]').forEach(btn => {
    btn.onclick = function() { updateStatus(this.dataset.id, 'spam') }
  })

  el.querySelectorAll('[data-action="view"]').forEach(btn => {
    btn.onclick = function() {
      el.querySelector('#viewAuthor').textContent = this.dataset.author
      el.querySelector('#viewEmail').textContent = this.dataset.email
      el.querySelector('#viewContent').textContent = this.dataset.content
      el.querySelector('#viewPost').textContent = this.dataset.post
      el.querySelector('#viewDate').textContent = this.dataset.date
      el.querySelector('#viewIp').textContent = this.dataset.ip || 'Not recorded'
      viewModal.style.display = 'flex'
    }
  })

  el.querySelectorAll('[data-action="delete"]').forEach(btn => {
    btn.onclick = function() { deleteCommentId = this.dataset.id; deleteModal.style.display = 'flex' }
  })

  viewModal.onclick = e => { if (e.target === viewModal) closeModals() }
  deleteModal.onclick = e => { if (e.target === deleteModal) closeModals() }

  // Escape key closes modals
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModals()
  })
})
</script>
@endsection
