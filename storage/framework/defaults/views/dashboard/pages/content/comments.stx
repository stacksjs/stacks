  <div class="flex gap-2" id="filterTabs">
    <button data-filter="all" class="inline-flex items-center justify-center font-medium tracking-tight transition-all duration-150 select-none focus:outline-none active:scale-[0.98] text-[12px] px-2.5 py-1 rounded-md gap-1.5 h-7 bg-gradient-to-b from-blue-500 to-blue-600 text-white shadow-sm shadow-blue-600/25">All ({{ stats.total }})</button>
    <button data-filter="pending" class="inline-flex items-center justify-center font-medium tracking-tight transition-all duration-150 select-none focus:outline-none active:scale-[0.98] text-[12px] px-2.5 py-1 rounded-md gap-1.5 h-7 bg-transparent text-neutral-600 dark:text-neutral-300 hover:bg-black/5 dark:hover:bg-white/8">Pending ({{ stats.pending }})</button>
    <button data-filter="approved" class="inline-flex items-center justify-center font-medium tracking-tight transition-all duration-150 select-none focus:outline-none active:scale-[0.98] text-[12px] px-2.5 py-1 rounded-md gap-1.5 h-7 bg-transparent text-neutral-600 dark:text-neutral-300 hover:bg-black/5 dark:hover:bg-white/8">Approved ({{ stats.approved }})</button>
    <button data-filter="spam" class="inline-flex items-center justify-center font-medium tracking-tight transition-all duration-150 select-none focus:outline-none active:scale-[0.98] text-[12px] px-2.5 py-1 rounded-md gap-1.5 h-7 bg-transparent text-neutral-600 dark:text-neutral-300 hover:bg-black/5 dark:hover:bg-white/8">Spam ({{ stats.spam }})</button>
