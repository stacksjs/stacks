@extends('layouts/default')

@section('content')
<script>
// Chart options
const chartOptions = {
  responsive: true,
  maintainAspectRatio: false,
  scales: {
    y: {
      beginAtZero: true,
      grid: {
        color: 'rgba(200, 200, 200, 0.1)',
      },
      ticks: {
        color: 'rgb(156, 163, 175)',
        font: {
          family: "'JetBrains Mono', monospace",
        },
        callback: (value) => {
          if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M'
          if (value >= 1000) return (value / 1000).toFixed(1) + 'k'
          return value
        }
      },
    },
    x: {
      grid: {
        display: false,
      },
      ticks: {
        color: 'rgb(156, 163, 175)',
        font: {
          family: "'JetBrains Mono', monospace",
        },
      },
    },
  },
  plugins: {
    legend: {
      display: true,
      position: 'top' as const,
      align: 'end' as const,
      labels: {
        color: 'rgb(156, 163, 175)',
        font: {
          family: "'JetBrains Mono', monospace",
        },
        boxWidth: 12,
        padding: 15,
      },
    },
    tooltip: {
      callbacks: {
        label: (context) => {
          let label = context.dataset.label || ''
          if (label) label += ': '
          if (context.parsed.y !== null) {
            const value = context.parsed.y
            if (value >= 1000000) label += (value / 1000000).toFixed(1) + 'M'
            else if (value >= 1000) label += (value / 1000).toFixed(1) + 'k'
            else label += value
          }
          return label + ' downloads'
        }
      }
    }
  },
  elements: {
    line: {
      tension: 0.4,
    },
  },
}

const timeRangeOptions = {
  '7': 'Last 7 days',
  '30': 'Last 30 days',
  '90': 'Last 90 days',
  '365': 'Last year'
} as const

let timeRange = '30'
let isLoading = false

// Helper function to format dates
const formatDate = (daysAgo) => {
  const date = new Date()
  date.setDate(date.getDate() - daysAgo)
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric'
  }
}

// Generate date labels for the selected time range
const generateDateLabels = (days) => {
  return Array.from({ length: days }, (_, i) => formatDate(days - 1 - i)).reverse()
}

interface ReleaseStats {
  labels: string[]
  downloads: number[]
  releaseTimes: number[]
}

interface ReleaseStatsMap {
  '7': ReleaseStats
  '30': ReleaseStats
  '90': ReleaseStats
  '365': ReleaseStats
}

let releaseStats = {
  '7': {
    labels: generateDateLabels(7),
    downloads: [12500, 15800, 14200, 16800, 19200, 18100, 17200],
    releaseTimes: [3.2, 2.8, 3.5, 2.9, 3.1, 3.4, 3.0]
  },
  '30': {
    labels: generateDateLabels(30),
    downloads: Array.from({ length: 30 }, () => Math.floor(Math.random() * 20000) + 10000),
    releaseTimes: Array.from({ length: 30 }, () => Math.random() * 2 + 2)
  },
  '90': {
    labels: generateDateLabels(90),
    downloads: Array.from({ length: 90 }, () => Math.floor(Math.random() * 20000) + 10000),
    releaseTimes: Array.from({ length: 90 }, () => Math.random() * 2 + 2)
  },
  '365': {
    labels: generateDateLabels(365),
    downloads: Array.from({ length: 365 }, () => Math.floor(Math.random() * 20000) + 10000),
    releaseTimes: Array.from({ length: 365 }, () => Math.random() * 2 + 2)
  }
}

// Function to fetch release data from API
let fetchError = ''

const fetchReleaseData = async (days) => {
  isLoading = true
  fetchError = ''
  try {
    const baseUrl = 'http://localhost:' + (process.env.PORT_API || '3008')
    const response = await fetch(`${baseUrl}/releases/stats?days=${days}`, {
      headers: { 'Accept': 'application/json' },
    })
    if (response.ok) {
      const data = await response.json()
      if (data.stats) {
        releaseStats[days] = data.stats
      }
    }
  } catch (error) {
    fetchError = 'Failed to load release data. Using cached data.'
    console.error('Failed to fetch release data:', error)
  } finally {
    isLoading = false
  }
}

// Chart data for downloads
function downloadsData() { return ({
  labels: releaseStats[timeRange].labels,
  datasets: [{
    label: 'Downloads',
    data: releaseStats[timeRange].downloads,
    borderColor: 'rgb(59, 130, 246)',
    backgroundColor: 'rgba(59, 130, 246, 0.1)',
    fill: true,
  }]
})}

// Chart data for release times
function releaseTimeData() { return ({
  labels: releaseStats[timeRange].labels,
  datasets: [{
    label: 'Release Time (minutes)',
    data: releaseStats[timeRange].releaseTimes,
    borderColor: 'rgb(234, 179, 8)',
    backgroundColor: 'rgba(234, 179, 8, 0.1)',
    fill: true,
  }]
}))

// Release time chart options (customize y-axis label)
const releaseTimeOptions = {
  ...chartOptions,
  plugins: {
    ...chartOptions.plugins,
    tooltip: {
      callbacks: {
        label: (context) => {
          let label = context.dataset.label || ''
          if (label) label += ': '
          if (context.parsed.y !== null) {
            label += context.parsed.y.toFixed(1) + ' mins'
          }
          return label
        }
      }
    }
  }
}

</script>

<div class="py-4 lg:py-8 min-h-screen dark:bg-neutral-800">
  <div class="mb-8 px-4 sm:px-6 lg:px-8">
    <div>
      <div class="flex items-center justify-between">
        <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-neutral-100">
