                  <div>
                    <label class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Subject Type</label>
                    <p class="mt-1 text-gray-900 text-sm dark:text-neutral-200">
                      {{ subjectTypes.find(s => s.type === selectedLog.subject_type)?.name || selectedLog.subject_type }}
                    </p>
                  </div>

                  <div>
                    <label class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Subject</label>
                    <p class="mt-1 text-gray-900 text-sm dark:text-neutral-200">{{ selectedLog.subject_name }}</p>
                  </div>

                  <div>
                    <label class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Subject ID</label>
                    <p class="mt-1 font-mono text-gray-900 text-sm dark:text-neutral-200">{{ selectedLog.subject_id }}</p>
                  </div>
                </div>
              </div>

              <!-- Changed attributes -->
              @if(selectedLog.properties?.attributes || selectedLog.properties?.old)
              <div>
                <h4 class="mb-2 font-medium text-base text-gray-900 dark:text-white">Changed Attributes</h4>

                <div class="overflow-hidden bg-gray-50 dark:bg-neutral-700 rounded-lg">
                  <div class="px-4 py-3 bg-gray-100 dark:bg-neutral-600 border-b border-gray-200 dark:border-neutral-600">
                    <div class="grid grid-cols-3 font-medium text-gray-500 text-xs uppercase dark:text-neutral-300">
                      <div>Attribute</div>
                      @if(selectedLog.properties?.old)
                      <div>Old Value</div>
                      @endif
                      <div>New Value</div>
                    </div>
                  </div>

                  <div class="divide-gray-200 divide-y dark:divide-neutral-600">
                    @if(selectedLog.properties?.attributes)
                    @foreach(selectedLog.properties.attributes as key => value)
<div
                      class="grid grid-cols-3 px-4 py-3 text-sm"
                      @show="key !== 'created_at' && key !== 'updated_at'"
                    >
                      <div class="font-medium text-gray-900 dark:text-white">{{ key }}</div>
                      @if(selectedLog.properties?.old)
                      <div class="text-gray-700 dark:text-neutral-300">
                        {{ selectedLog.properties.old[key] || '-' }}
                      </div>
                      @endif
                      <div class="text-gray-900 dark:text-white">{{ value }}</div>
                    </div>
                    @elseif(selectedLog.properties?.old)
                    @foreach(selectedLog.properties.old as key => value)
<div
                      class="grid grid-cols-3 px-4 py-3 text-sm"
                      @show="key !== 'created_at' && key !== 'updated_at'"
                    >
                      <div class="font-medium text-gray-900 dark:text-white">{{ key }}</div>
                      <div class="text-gray-700 dark:text-neutral-300">{{ value }}</div>
                      <div class="text-gray-900 dark:text-white">-</div>
                    </div>
                    @endif
                  </div>
                </div>
              </div>
              @endif

              <!-- Additional metadata -->
              @if(selectedLog.properties && Object.keys(selectedLog.properties).some(key => key !== 'attributes' && key !== 'old'))
              <div>
                <h4 class="mb-2 font-medium text-base text-gray-900 dark:text-white">Additional Metadata</h4>
                <div class="p-4 bg-gray-50 dark:bg-neutral-700 rounded-lg">
                  @foreach(selectedLog.properties as key => value)
<div
                    @show="key !== 'attributes' && key !== 'old'"
                    class="mb-3 last:mb-0"
                  >
                    <label class="block capitalize font-medium text-gray-700 text-sm dark:text-neutral-300">{{ key }}</label>
                    <div class="mt-1">
                      @if(typeof value === 'string')
                      <span class="text-gray-900 text-sm dark:text-neutral-200">
                        {{ value }}
                      </span>
                      @else
                      <pre class="overflow-x-auto p-2 text-gray-900 text-sm dark:text-neutral-200 bg-gray-100 dark:bg-neutral-600 rounded">{{ JSON.stringify(value, null, 2) }}</pre>
                      @endif
                    </div>
                  </div>
                </div>
              </div>
              @endif
            </div>
            @endif
          </div>
        </div>
