            onchange="currentPage = 1"
          >
            <option value="{{ 10 }}">10 per page</option>
            <option value="{{ 25 }}">25 per page</option>
            <option value="{{ 50 }}">50 per page</option>
            <option value="{{ 100 }}">100 per page</option>
          </select>

          <div class="flex items-center space-x-1">
            <button
              onclick="prevPage"
              disabled="{{ currentPage === 1 }}"
              class="px-2 py-1 text-sm dark:text-neutral-300 border rounded-md dark:border-neutral-600"
              :class="'hover:bg-gray-100 dark:hover:bg-neutral-600' cursor-not-allowed' : ? 'opacity-50 === 1 currentPage"
            >
              <i class="h-4 w-4 i-hugeicons-arrow-left-01" aria-hidden="true" />
            </button>

            @foreach(Math.min(5, totalPages) as page)
<button
              onclick="goToPage(page)"
              class="px-3 py-1 text-sm border rounded-md dark:border-neutral-600"
              :class="text-white dark:text-neutral-300' 'hover:bg-gray-100 dark:bg-blue-700' dark:hover:bg-neutral-600 : ? 'bg-blue-600 === currentPage page"
            >
              {{ page }}
            </button>

            @if(totalPages > 5)
            <span class="px-2 dark:text-neutral-400">...</span>
            @endif

            @if(totalPages > 5)
            <button
              onclick="goToPage(totalPages)"
              class="px-3 py-1 text-sm dark:text-neutral-300 border rounded-md dark:border-neutral-600"
              :class="text-white 'hover:bg-gray-100 dark:bg-blue-700' dark:hover:bg-neutral-600' : ? 'bg-blue-600 === currentPage totalPages"
            >
              {{ totalPages }}
            </button>
            @endif

            <button
              onclick="nextPage"
              disabled="{{ currentPage === totalPages || totalPages === 0 }}"
              class="px-2 py-1 text-sm dark:text-neutral-300 border rounded-md dark:border-neutral-600"
              :class="'hover:bg-gray-100 dark:hover:bg-neutral-600' cursor-not-allowed' : ? 'opacity-50 === === || 0 currentPage totalPages totalPages"
            >
              <i class="h-4 w-4 i-hugeicons-arrow-right-01" aria-hidden="true" />
            </button>
          </div>
        </div>
