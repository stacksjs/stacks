                        <option value="NewsArticle">News Article</option>
                        <option value="TechArticle">Tech Article</option>
                        <option value="Review">Review</option>
                        <option value="HowTo">How-To</option>
                        <option value="FAQ">FAQ</option>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <!-- SEO Preview -->
              <div class="mt-6 p-4 border border-gray-200 rounded-md dark:border-neutral-700">
                <h4 class="font-medium text-gray-900 text-sm dark:text-white">Google Search Preview</h4>
                <div class="mt-2 space-y-1">
                  <div class="text-blue-600 text-lg dark:text-blue-400 hover:underline">{{ currentSeo.title }}</div>
                  <div class="text-green-600 text-sm dark:text-green-400">{{ currentSeo.canonicalUrl }}</div>
                  <div class="text-gray-600 text-sm dark:text-neutral-300">{{ currentSeo.metaDescription.substring(0, 160) }}{{ currentSeo.metaDescription.length > 160 ? '...' : '' }}</div>
