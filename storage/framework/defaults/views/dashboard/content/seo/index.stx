// Global SEO settings
let globalSeoSettings = {
  siteName: 'My Tech Blog',
  separator: ' | ',
  titleFormat: '%post_title% %separator% %site_name%',
  metaDescription: 'A blog about web development, programming, and technology.',
  ogImage: 'https://picsum.photos/seed/global/1200/630',
  twitterUsername: '@mytechblog',
  twitterCardType: 'summary_large_image',
  facebookAppId: '123456789012345',
  defaultSchema: 'Article',
  googleVerification: 'abcdefghijklmnopqrstuvwxyz',
  bingVerification: '1234567890ABCDEFGHIJKL',
  robotsTxt: 'User-agent: *\nDisallow: /admin/\nDisallow: /dashboard/\nSitemap: https://example.com/sitemap.xml',
  sitemapEnabled: true,
  sitemapFrequency: 'weekly'
}

// Filter and sort options
let searchQuery = ''
let sortBy = 'score'
let sortOrder = 'desc'
let itemsPerPage = 10
let currentPage = 1

// Edit SEO Modal
let showEditModal = false
let currentSeo = null

// Global Settings Modal
let showGlobalSettingsModal = false

// Bulk Optimization Modal
let showBulkOptimizationModal = false
let selectedPostIds = []
let selectAll = false

// SEO Analysis Modal
let showAnalysisModal = false
let analysisPostId = null

// Computed properties
function filteredSeoData() {
  let result = [...seoData]

  // Apply search filter
  if (searchQuery) {
    const query = searchQuery.toLowerCase()
    result = result.filter(item =>
      item.title.toLowerCase().includes(query) ||
      item.metaDescription.toLowerCase().includes(query) ||
      item.focusKeyword.toLowerCase().includes(query) ||
      item.slug.toLowerCase().includes(query)
    )
  }

  // Apply sorting
  result.sort((a, b) => {
    const sortField = sortBy as keyof SeoSettings
    let aValue = a[sortField]
    let bValue = b[sortField]

    // Handle string comparison
    if (typeof aValue === 'string' && typeof bValue === 'string') {
      aValue = aValue.toLowerCase()
      bValue = bValue.toLowerCase()
    }

    if (sortOrder === 'asc') {
      return aValue > bValue ? 1 : -1
    } else {
      return aValue < bValue ? 1 : -1
    }
  }

  return result
}

// Pagination
function totalPages() { return Math.ceil(filteredSeoData.length / itemsPerPage) }

function paginatedSeoData() {
  const startIndex = (currentPage - 1) * itemsPerPage
  const endIndex = startIndex + itemsPerPage
  return filteredSeoData.slice(startIndex, endIndex)
}

function paginationRange() {
  const range: number[] = []
  const maxVisiblePages = 5
  const startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2))
  const endPage = Math.min(totalPages, startPage + maxVisiblePages - 1)

  for (let i = startPage; i <= endPage; i++) {
    range.push(i)
  }

  return range
}

// Methods
function openEditModal(seo: SeoSettings): void {
  currentSeo = { ...seo }
  showEditModal = true
}

function closeEditModal(): void {
  showEditModal = false
  currentSeo = null
}

function saveSeoSettings(): void {
  if (!currentSeo) return

  const index = seoData.findIndex(item => item.id === currentSeo.value!.id)
  if (index !== -1) {
    // Make a copy of the current SEO settings
    const updatedSeo = { ...currentSeo };

    // Ensure slug is a string
    if (updatedSeo.slug === undefined) {
      updatedSeo.slug = '';
    }

    // Update the last updated date
    updatedSeo.lastUpdated = new Date().toISOString().split('T')[0];

    // Update the SEO data
    seoData[index] = updatedSeo;
  }

  closeEditModal()
}

function openGlobalSettingsModal(): void {
  showGlobalSettingsModal = true
}

function closeGlobalSettingsModal(): void {
  showGlobalSettingsModal = false
}

function saveGlobalSettings(): void {
  // In a real app, this would save to the server
  closeGlobalSettingsModal()
}

function openBulkOptimizationModal(): void {
  showBulkOptimizationModal = true
}

function closeBulkOptimizationModal(): void {
  showBulkOptimizationModal = false
  selectedPostIds = []
  selectAll = false
}

function runBulkOptimization(): void {
  // In a real app, this would trigger optimization for selected posts
  closeBulkOptimizationModal()
}

function openAnalysisModal(postId: number): void {
  analysisPostId = postId
  showAnalysisModal = true
}

function closeAnalysisModal(): void {
  showAnalysisModal = false
  analysisPostId = null
}

function toggleSelectAll(): void {
  if (selectAll) {
    // Select all posts
    selectedPostIds = paginatedSeoData.map(item => item.id)
  } else {
    // Deselect all
    selectedPostIds = []
  }
}

function togglePostSelection(postId: number): void {
  const index = selectedPostIds.indexOf(postId)
  if (index === -1) {
    selectedPostIds.push(postId)
  } else {
    selectedPostIds.splice(index, 1)
  }

  // Update selectAll based on whether all posts are selected
  selectAll = paginatedSeoData.every(item => selectedPostIds.includes(item.id))
}

// Get score color class
const getScoreColorClass = (score: number): string => {
  if (score >= 90) return 'text-green-600 dark:text-green-400'
  if (score >= 70) return 'text-yellow-600 dark:text-yellow-400'
  return 'text-red-600 dark:text-red-400'
}

// Get score background class
const getScoreBgClass = (score: number): string => {
  if (score >= 90) return 'bg-green-100 dark:bg-green-900/30'
  if (score >= 70) return 'bg-yellow-100 dark:bg-yellow-900/30'
  return 'bg-red-100 dark:bg-red-900/30'
}

function hasSelectedPosts() { return selectedPostIds.length > 0 }

// Generate preview for title and description
function generateSeoPreview(seo: SeoSettings): string {
  return seo.title + ' - ' + seo.metaDescription.substring(0, 160) + (seo.metaDescription.length > 160 ? '...' : '')
}

// Get post title by ID
function getPostTitleById(id: number): string {
  const post = posts.find(p => p.id === id)
  return post ? post.title : 'Unknown Post'
}
</script>

<main>
