                  <a href="#" class="px-1 py-4 font-medium text-blue-600 text-sm whitespace-nowrap dark:text-blue-400 border-b-2 border-blue-500">
                    Basic SEO
                  </a>
                  <a href="#" class="px-1 py-4 font-medium text-gray-500 text-sm whitespace-nowrap dark:text-neutral-400 hover:text-gray-700 dark:hover:text-gray-300 border-b-2 border-transparent hover:border-gray-300 dark:hover:border-gray-600">
                    Social Media
                  </a>
                  <a href="#" class="px-1 py-4 font-medium text-gray-500 text-sm whitespace-nowrap dark:text-neutral-400 hover:text-gray-700 dark:hover:text-gray-300 border-b-2 border-transparent hover:border-gray-300 dark:hover:border-gray-600">
                    Advanced
                  </a>
                </nav>
              </div>

              <!-- Basic SEO Tab Content -->
              <div>
                <div class="space-y-4">
                  <div>
                    <label for="seo-title" class="block font-medium leading-6 text-gray-900 text-sm dark:text-white">SEO Title</label>
                    <div class="mt-2">
                      <input
                        type="text"
                        id="seo-title"
                        value="{{ currentSeo.title }}"
                        class="block py-1.5 w-full text-gray-900 sm:leading-6 sm:text-sm dark:text-white placeholder:text-gray-400 dark:placeholder:text-neutral-500 dark:bg-neutral-700 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 focus:ring-2 focus:ring-blue-600 focus:ring-inset shadow-sm"
                      />
                    </div>
                    <p class="mt-1 text-gray-500 text-xs dark:text-neutral-400">
                      {{ currentSeo.title.length }}/60 characters
                      @if(currentSeo.title.length > 60)
<span class="text-red-500 dark:text-red-400">
                        (Too long)
                      </span>
                    </p>
                  </div>

                  <div>
                    <label for="seo-slug" class="block font-medium leading-6 text-gray-900 text-sm dark:text-white">Slug</label>
                    <div class="mt-2">
                      <input
                        type="text"
                        id="seo-slug"
                        value="{{ currentSeo.slug }}"
                        class="block py-1.5 w-full text-gray-900 sm:leading-6 sm:text-sm dark:text-white placeholder:text-gray-400 dark:placeholder:text-neutral-500 dark:bg-neutral-700 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 focus:ring-2 focus:ring-blue-600 focus:ring-inset shadow-sm"
                      />
