                <h4 class="font-medium text-gray-900 text-sm dark:text-white">robots.txt</h4>
                <div class="mt-2">
                  <textarea
                    value="{{ globalSeoSettings.robotsTxt }}"
                    rows="6"
                    class="block py-1.5 w-full font-mono text-gray-900 sm:leading-6 sm:text-sm dark:text-white placeholder:text-gray-400 dark:placeholder:text-neutral-500 dark:bg-neutral-700 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 focus:ring-2 focus:ring-blue-600 focus:ring-inset shadow-sm"
                  ></textarea>
                </div>
              </div>
            </div>
          </div>
          <div class="sm:grid sm:gap-3 sm:grid-cols-2 sm:grid-flow-row-dense mt-5 sm:mt-6">
            <button
              type="button"
              onclick="saveGlobalSettings"
              class="inline-flex justify-center sm:col-start-2 px-3 py-2 w-full font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 focus-visible:outline-offset-2 shadow-sm"
            >
              Save Settings
            </button>
            <button
              type="button"
              onclick="closeGlobalSettingsModal"
              class="inline-flex justify-center sm:col-start-1 mt-3 px-3 py-2 sm:mt-0 w-full font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bulk Optimization Modal -->
  @if(showBulkOptimizationModal)
<div class="relative z-10" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-neutral-900 dark:bg-opacity-75 transition-opacity"></div>

    <div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
        <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
          <div class="hidden sm:block absolute right-0 top-0 pr-4 pt-4">
            <button
              type="button"
              onclick="closeBulkOptimizationModal"
              class="text-gray-400 dark:text-neutral-300 hover:text-gray-500 dark:hover:text-gray-200 bg-white dark:bg-neutral-800 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              <span class="sr-only">Close</span>
              <div class="h-6 w-6 i-hugeicons-cancel-circle"></div>
            </button>
          </div>
          <div class="sm:flex sm:items-start">
            <div class="flex flex-shrink-0 items-center justify-center mx-auto sm:mx-0 h-12 w-12 sm:h-10 sm:w-10 bg-blue-100 dark:bg-blue-900/30 rounded-full">
              <div class="h-6 w-6 text-blue-600 dark:text-blue-400 i-hugeicons-magic-wand-05"></div>
            </div>
            <div class="mt-3 sm:ml-4 sm:mt-0 text-center sm:text-left">
              <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white" id="modal-title">Bulk SEO Optimization</h3>
              <div class="mt-2">
                <p class="text-gray-500 text-sm dark:text-neutral-400">
                  Automatically optimize SEO settings for the selected posts.
                </p>
              </div>
            </div>
          </div>
          <div class="mt-5 sm:mt-4">
            <div class="space-y-4">
              <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-md">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <div class="h-5 w-5 text-blue-400 i-hugeicons-info-circle"></div>
                  </div>
                  <div class="md:flex flex-1 md:justify-between ml-3">
                    <p class="text-blue-700 text-sm dark:text-blue-300">
                      {{ selectedPostIds.length }} posts selected for optimization
                    </p>
                  </div>
                </div>
              </div>

              <div>
                <h4 class="font-medium text-gray-900 text-sm dark:text-white">Optimization Options</h4>
                <div class="mt-4 space-y-4">
                  <div class="flex relative items-start">
                    <div class="flex items-center h-6">
                      <input
                        id="optimize-titles"
                        type="checkbox"
                        checked
                        class="h-4 w-4 text-blue-600 dark:bg-neutral-700 dark:checked:bg-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-600 dark:focus:ring-offset-neutral-800"
                      />
                    </div>
                    <div class="ml-3 leading-6 text-sm">
                      <label for="optimize-titles" class="font-medium text-gray-900 dark:text-white">Optimize Titles</label>
                      <p class="text-gray-500 dark:text-neutral-400">Generate SEO-friendly titles based on content</p>
                    </div>
                  </div>

                  <div class="flex relative items-start">
                    <div class="flex items-center h-6">
                      <input
                        id="optimize-descriptions"
                        type="checkbox"
                        checked
                        class="h-4 w-4 text-blue-600 dark:bg-neutral-700 dark:checked:bg-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-600 dark:focus:ring-offset-neutral-800"
                      />
                    </div>
                    <div class="ml-3 leading-6 text-sm">
                      <label for="optimize-descriptions" class="font-medium text-gray-900 dark:text-white">Generate Meta Descriptions</label>
                      <p class="text-gray-500 dark:text-neutral-400">Create compelling meta descriptions</p>
                    </div>
                  </div>

                  <div class="flex relative items-start">
                    <div class="flex items-center h-6">
                      <input
                        id="extract-keywords"
                        type="checkbox"
                        checked
                        class="h-4 w-4 text-blue-600 dark:bg-neutral-700 dark:checked:bg-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-600 dark:focus:ring-offset-neutral-800"
                      />
                    </div>
                    <div class="ml-3 leading-6 text-sm">
                      <label for="extract-keywords" class="font-medium text-gray-900 dark:text-white">Extract Focus Keywords</label>
                      <p class="text-gray-500 dark:text-neutral-400">Identify the best focus keywords from content</p>
                    </div>
                  </div>

                  <div class="flex relative items-start">
                    <div class="flex items-center h-6">
                      <input
                        id="optimize-social"
                        type="checkbox"
                        checked
                        class="h-4 w-4 text-blue-600 dark:bg-neutral-700 dark:checked:bg-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-600 dark:focus:ring-offset-neutral-800"
                      />
                    </div>
                    <div class="ml-3 leading-6 text-sm">
                      <label for="optimize-social" class="font-medium text-gray-900 dark:text-white">Optimize Social Media</label>
                      <p class="text-gray-500 dark:text-neutral-400">Generate social media titles and descriptions</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="sm:grid sm:gap-3 sm:grid-cols-2 sm:grid-flow-row-dense mt-5 sm:mt-6">
            <button
              type="button"
              onclick="runBulkOptimization"
              class="inline-flex justify-center sm:col-start-2 px-3 py-2 w-full font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 focus-visible:outline-offset-2 shadow-sm"
            >
              Run Optimization
            </button>
            <button
              type="button"
              onclick="closeBulkOptimizationModal"
              class="inline-flex justify-center sm:col-start-1 mt-3 px-3 py-2 sm:mt-0 w-full font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SEO Analysis Modal -->
  @if(showAnalysisModal)
<div class="relative z-10" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-neutral-900 dark:bg-opacity-75 transition-opacity"></div>

    <div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
        <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-3xl sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
          <div class="hidden sm:block absolute right-0 top-0 pr-4 pt-4">
            <button
              type="button"
              onclick="closeAnalysisModal"
              class="text-gray-400 dark:text-neutral-300 hover:text-gray-500 dark:hover:text-gray-200 bg-white dark:bg-neutral-800 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              <span class="sr-only">Close</span>
              <div class="h-6 w-6 i-hugeicons-cancel-circle"></div>
            </button>
          </div>
          <div class="sm:flex sm:items-start">
            <div class="flex flex-shrink-0 items-center justify-center mx-auto sm:mx-0 h-12 w-12 sm:h-10 sm:w-10 bg-blue-100 dark:bg-blue-900/30 rounded-full">
              <div class="h-6 w-6 text-blue-600 dark:text-blue-400 i-hugeicons-presentation-bar-chart-02"></div>
            </div>
            <div class="mt-3 sm:ml-4 sm:mt-0 text-center sm:text-left">
              <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white" id="modal-title">SEO Analysis</h3>
              <div class="mt-2">
                <p class="text-gray-500 text-sm dark:text-neutral-400">
                  Detailed SEO analysis for "{{ analysisPostId ? getPostTitleById(analysisPostId) : '' }}"
                </p>
              </div>
            </div>
          </div>
          @if(analysisPostId)
<div class="mt-5 sm:mt-4">
            <div class="space-y-6">
              <!-- Overall Score -->
              <div class="flex items-center justify-between">
                <div>
                  <h4 class="font-medium text-gray-900 text-lg dark:text-white">Overall SEO Score</h4>
                  <p class="text-gray-500 text-sm dark:text-neutral-400">Based on multiple factors</p>
                </div>
                <div class="flex items-center">
                  <div
                    class="flex items-center justify-center h-16 w-16 font-bold text-xl rounded-full"
                    :class="=== => || 0) analysisPostId)?.score getScoreBgClass(seoData.find(item item.id"
                  >
                    <span :class="=== => || 0) analysisPostId)?.score getScoreColorClass(seoData.find(item item.id">
                      {{ seoData.find(item => item.id === analysisPostId)?.score || 0 }}%
                    </span>
                  </div>
                </div>
              </div>

              <!-- Analysis Sections -->
              <div class="space-y-4">
                <!-- Content Analysis -->
                <div class="overflow-hidden border border-gray-200 rounded-md dark:border-neutral-700">
                  <div class="px-4 py-3 bg-gray-50 dark:bg-neutral-700">
                    <h5 class="font-medium text-gray-900 text-sm dark:text-white">Content Analysis</h5>
                  </div>
                  <div class="px-4 py-3 divide-gray-200 divide-y dark:divide-neutral-700">
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Focus keyword appears in the title</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your focus keyword is used in the SEO title</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Focus keyword appears in the meta description</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your focus keyword is used in the meta description</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-yellow-500 dark:text-yellow-400 i-hugeicons-alert-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Content length could be improved</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your content is 850 words. Consider expanding to at least 1000 words for better ranking.</p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Technical Analysis -->
                <div class="overflow-hidden border border-gray-200 rounded-md dark:border-neutral-700">
                  <div class="px-4 py-3 bg-gray-50 dark:bg-neutral-700">
                    <h5 class="font-medium text-gray-900 text-sm dark:text-white">Technical Analysis</h5>
                  </div>
                  <div class="px-4 py-3 divide-gray-200 divide-y dark:divide-neutral-700">
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">URL is SEO friendly</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your URL is concise and contains your focus keyword</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Schema markup is implemented</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your page includes proper schema markup</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-red-500 dark:text-red-400 i-hugeicons-cancel-circle"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Missing image alt tags</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">3 images on your page are missing alt tags</p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Readability Analysis -->
                <div class="overflow-hidden border border-gray-200 rounded-md dark:border-neutral-700">
                  <div class="px-4 py-3 bg-gray-50 dark:bg-neutral-700">
                    <h5 class="font-medium text-gray-900 text-sm dark:text-white">Readability Analysis</h5>
                  </div>
                  <div class="px-4 py-3 divide-gray-200 divide-y dark:divide-neutral-700">
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Good use of headings</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your content uses proper heading structure</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-yellow-500 dark:text-yellow-400 i-hugeicons-alert-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Paragraph length</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Some paragraphs are too long. Consider breaking them up for better readability.</p>
                      </div>
                    </div>
                    <div class="flex items-start py-3">
                      <div class="flex-shrink-0">
                        <div class="h-5 w-5 text-green-500 dark:text-green-400 i-hugeicons-checkmark-circle-02"></div>
                      </div>
                      <div class="ml-3">
                        <p class="font-medium text-gray-900 text-sm dark:text-white">Reading ease score is good</p>
                        <p class="text-gray-500 text-xs dark:text-neutral-400">Your content has a Flesch reading ease score of 68, which is considered good</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Improvement Suggestions -->
              <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-md">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <div class="h-5 w-5 text-blue-400 i-hugeicons-idea-01"></div>
                  </div>
                  <div class="ml-3">
                    <h3 class="font-medium text-blue-800 text-sm dark:text-blue-300">Improvement Suggestions</h3>
                    <div class="mt-2 text-blue-700 text-sm dark:text-blue-300">
                      <ul class="pl-5 space-y-1 list-disc">
                        <li>Add alt tags to all images</li>
                        <li>Increase content length to at least 1000 words</li>
                        <li>Break up longer paragraphs for better readability</li>
                        <li>Add more internal links to related content</li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="sm:grid sm:gap-3 sm:grid-cols-2 sm:grid-flow-row-dense mt-5 sm:mt-6">
            <button
              type="button"
              onclick="openEditModal(seoData.find(item => item.id === analysisPostId) as SeoSettings)"
              class="inline-flex justify-center sm:col-start-2 px-3 py-2 w-full font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 focus-visible:outline-offset-2 shadow-sm"
            >
              Edit SEO Settings
            </button>
            <button
              type="button"
              onclick="closeAnalysisModal"
              class="inline-flex justify-center sm:col-start-1 mt-3 px-3 py-2 sm:mt-0 w-full font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
            >
              Close
            </button>
          </div>
        </div>
      </div>
    </div>
</div>

@endsection
