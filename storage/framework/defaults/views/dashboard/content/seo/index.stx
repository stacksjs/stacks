              <div class="mt-2">
                <p class="text-gray-500 text-sm dark:text-neutral-400">
                  Optimize your post's SEO settings to improve search engine visibility.
                </p>
              </div>
            </div>
          </div>
          @if(currentSeo)
<div class="mt-5 sm:mt-4">
            <div class="space-y-4">
