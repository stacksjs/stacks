@section('content')
@title('Dashboard - File Manager')
<div class="flex flex-col h-full">
  <div class="flex flex-1">
    <div class="border-r border-stone-200/60 dark:border-neutral-700 bg-[#F5F3EE]/80 dark:bg-neutral-800 transition-all duration-300 {{ sidePanelClass }}">
