        </div>
        <div class="flex space-x-2">
          <button
            onclick="currentPage = Math.max(1, currentPage - 1)"
            disabled="{{ currentPage === 1 }}"
            class="'opacity-50 { {{ } }} === 1 currentPage cursor-not-allowed':"
            class="inline-flex items-center px-3 py-1.5 font-medium text-gray-700 text-sm dark:text-neutral-200 bg-white dark:bg-neutral-600 hover:bg-gray-50 dark:hover:bg-neutral-500 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
          >
            Previous
          </button>
          <div class="flex space-x-1">
            @foreach(paginationRange as page)
<button
              onclick="currentPage = page"
              class="text-gray-700 text-white dark:text-neutral-200 dark:bg-neutral-600 hover:bg-gray-50 !== 'bg-blue-600 'bg-white { {{ } }} === currentPage currentPage page page, hover:bg-blue-500': dark:hover:bg-neutral-500':"
              class="inline-flex items-center px-3 py-1.5 font-medium text-sm ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
            >
              {{ page }}
            </button>
          </div>
          <button
            onclick="currentPage = Math.min(totalPages, currentPage + 1)"
            disabled="{{ currentPage === totalPages }}"
            class="'opacity-50 { {{ } }} === currentPage cursor-not-allowed': totalPages"
            class="inline-flex items-center px-3 py-1.5 font-medium text-gray-700 text-sm dark:text-neutral-200 bg-white dark:bg-neutral-600 hover:bg-gray-50 dark:hover:bg-neutral-500 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
          >
