            </div>
          </div>

          <div class="sm:flex sm:flex-row-reverse px-4 py-3 sm:px-6 bg-gray-50 dark:bg-neutral-800">
            <button
              type="button"
              onclick="createAuthor"
              class="inline-flex justify-center px-4 py-2 sm:ml-3 w-full sm:w-auto font-medium text-base text-white sm:text-sm bg-blue-600 hover:bg-blue-700 border border-transparent rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
            >
              Create
            </button>
            <button
              type="button"
              onclick="closeNewAuthorModal"
              class="inline-flex justify-center mt-3 px-4 py-2 sm:ml-3 sm:mt-0 w-full sm:w-auto font-medium text-base text-gray-700 sm:text-sm dark:text-neutral-200 bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 border border-gray-300 rounded-md dark:border-neutral-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Edit Author Modal -->
    @if(showEditModal)
<div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex sm:block items-end justify-center pb-20 pt-4 px-4 sm:p-0 min-h-screen text-center">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeEditModal"></div>

        <span class="hidden sm:inline-block sm:h-screen sm:align-middle" aria-hidden="true">&#8203;</span>

        <div class="inline-block overflow-hidden sm:my-8 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-700 rounded-lg shadow-xl transition-all transform align-bottom sm:align-middle">
          <div class="pb-4 pt-5 px-4 sm:p-6 sm:pb-4 bg-white dark:bg-neutral-700">
            <div class="sm:flex sm:items-start">
              <div class="flex flex-shrink-0 items-center justify-center mx-auto sm:mx-0 h-12 w-12 sm:h-10 sm:w-10 bg-blue-100 dark:bg-blue-900 rounded-full">
                <svg class="h-6 w-6 text-blue-600 dark:text-blue-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                </svg>
              </div>
              <div class="mt-3 sm:ml-4 sm:mt-0 text-center sm:text-left">
                <h3 class="font-medium leading-6 text-gray-900 text-lg dark:text-neutral-100">Edit Author</h3>
                <div class="mt-2">
                  <p class="text-gray-500 text-sm dark:text-neutral-400">
                    Update author information and permissions.
                  </p>
                </div>
              </div>
            </div>

            @if(authorToEdit)
<div class="mt-6 space-y-4">
              <div>
                <label for="edit-name" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Name</label>
                <input
                  type="text"
                  id="edit-name"
                  value="{{ authorToEdit.name }}"
                  class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-600 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                />
              </div>

              <div>
                <label for="edit-email" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Email</label>
                <input
                  type="email"
                  id="edit-email"
                  value="{{ authorToEdit.email }}"
                  class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-600 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                />
              </div>

              <div>
                <label for="edit-role" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Role</label>
                <select
                  id="edit-role"
                  value="{{ authorToEdit.role }}"
                  class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-600 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                >
                  <option value="admin">Admin</option>
                  <option value="editor">Editor</option>
                  <option value="contributor">Contributor</option>
                </select>
              </div>

              <div>
                <label for="edit-bio" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Bio</label>
                <textarea
                  id="edit-bio"
                  value="{{ authorToEdit.bio }}"
                  rows="3"
                  class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-600 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                ></textarea>
              </div>

              <div>
                <label for="edit-posts" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Post Count</label>
                <input
                  type="number"
                  id="edit-posts"
                  value="{{ authorToEdit.postCount }}"
                  class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-600 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                />
              </div>
            </div>
          </div>

          <div class="sm:flex sm:flex-row-reverse px-4 py-3 sm:px-6 bg-gray-50 dark:bg-neutral-800">
            <button
              type="button"
              onclick="updateAuthor"
              class="inline-flex justify-center px-4 py-2 sm:ml-3 w-full sm:w-auto font-medium text-base text-white sm:text-sm bg-blue-600 hover:bg-blue-700 border border-transparent rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
            >
              Save Changes
            </button>
            <button
              type="button"
              onclick="closeEditModal"
              class="inline-flex justify-center mt-3 px-4 py-2 sm:ml-3 sm:mt-0 w-full sm:w-auto font-medium text-base text-gray-700 sm:text-sm dark:text-neutral-200 bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 border border-gray-300 rounded-md dark:border-neutral-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    @if(showDeleteConfirmation)
<div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex sm:block items-end justify-center pb-20 pt-4 px-4 sm:p-0 min-h-screen text-center">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeDeleteModal"></div>

        <span class="hidden sm:inline-block sm:h-screen sm:align-middle" aria-hidden="true">&#8203;</span>

        <div class="inline-block overflow-hidden sm:my-8 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-700 rounded-lg shadow-xl transition-all transform align-bottom sm:align-middle">
          <div class="pb-4 pt-5 px-4 sm:p-6 sm:pb-4 bg-white dark:bg-neutral-700">
            <div class="sm:flex sm:items-start">
              <div class="flex flex-shrink-0 items-center justify-center mx-auto sm:mx-0 h-12 w-12 sm:h-10 sm:w-10 bg-red-100 dark:bg-red-900 rounded-full">
                <svg class="h-6 w-6 text-red-600 dark:text-red-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
              </div>
              <div class="mt-3 sm:ml-4 sm:mt-0 text-center sm:text-left">
                <h3 class="font-medium leading-6 text-gray-900 text-lg dark:text-neutral-100">Delete Confirmation</h3>
                <div class="mt-2">
                  <p class="text-gray-500 text-sm dark:text-neutral-400">
                    {{ selectedAuthorIds.length > 1
                      ? `Are you sure you want to delete ${selectedAuthorIds.length} authors? This action cannot be undone.`
                      : authorToDelete
                        ? `Are you sure you want to delete ${authorToDelete.name}? This action cannot be undone.`
                        : 'Are you sure you want to delete this author? This action cannot be undone.' }}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="sm:flex sm:flex-row-reverse px-4 py-3 sm:px-6 bg-gray-50 dark:bg-neutral-800">
            <button
              type="button"
              onclick="deleteSelectedAuthors"
              class="inline-flex justify-center px-4 py-2 sm:ml-3 w-full sm:w-auto font-medium text-base text-white sm:text-sm bg-red-600 hover:bg-red-700 border border-transparent rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 shadow-sm"
            >
              Delete
            </button>
            <button
              type="button"
              onclick="closeDeleteModal"
              class="inline-flex justify-center mt-3 px-4 py-2 sm:ml-3 sm:mt-0 w-full sm:w-auto font-medium text-base text-gray-700 sm:text-sm dark:text-neutral-200 bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 border border-gray-300 rounded-md dark:border-neutral-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

<style scoped>
/* Add these styles for the diagram */
:deep(svg) {
  background-color: transparent;
  border-radius: 0.5rem;
}

:deep(line) {
  stroke-linecap: round;
}

:deep(text) {
  user-select: none;
}

:deep(circle) {
  cursor: pointer;
  transition: r 0.2s ease;
}

:deep(g:hover) text {
  font-weight: bold;
}

/* Chart styles */
.chart-container {
  position: relative;
  height: 400px;
}

/* Table styles */
.authors-table th {
  font-weight: 600;
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.05em;
}

.authors-table tbody tr {
  transition: background-color 0.2s;
}

.authors-table tbody tr:hover {
  background-color: rgba(243, 244, 246, 0.5);
}

.dark .authors-table tbody tr:hover {
  background-color: rgba(55, 65, 81, 0.3);
}

/* Badge styles */
.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.125rem 0.5rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: capitalize;
}

.role-badge.admin {
  background-color: rgba(79, 70, 229, 0.1);
  color: rgb(79, 70, 229);
}

.role-badge.editor {
  background-color: rgba(16, 185, 129, 0.1);
  color: rgb(16, 185, 129);
}

.role-badge.contributor {
  background-color: rgba(245, 158, 11, 0.1);
  color: rgb(245, 158, 11);
}

.dark .role-badge.admin {
  background-color: rgba(99, 102, 241, 0.2);
  color: rgb(165, 180, 252);
}

.dark .role-badge.editor {
  background-color: rgba(16, 185, 129, 0.2);
  color: rgb(110, 231, 183);
}

.dark .role-badge.contributor {
  background-color: rgba(245, 158, 11, 0.2);
  color: rgb(252, 211, 77);
}
</style>

<script client>
const { Chart, registerables } = await import('chart.js/auto')
Chart.register(...registerables)

const chart_1_ctx = document.getElementById('chart_1')
if (chart_1_ctx) {
  new Chart(chart_1_ctx, {
    type: 'line',
    data: chartData,
    options: chartOptions,
  })
}

</script>

@endsection
