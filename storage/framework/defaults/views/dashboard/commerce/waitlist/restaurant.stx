// Products derived from waitlist entries
const products = computed<Product[]>(() => {
  const productMap = new Map<string, number>()

  waitlistEntries.forEach(entry => {
    const count = productMap.get(entry.name) || 0
    productMap.set(entry.name, count + 1)
  }

  return Array.from(productMap.entries()).map(([name, count], index) => ({
    id: index + 1,
    name,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
    count
  }))
}

// Search and filter refs
let searchQuery = ''
let statusFilter = 'all'
let partySizeFilter = 'all'
let tablePreferenceFilter = 'all'

// Filter functions
function filteredEntries() {
  return waitlistEntries.filter(entry => {
    // Apply search filter
    const matchesSearch = searchQuery === '' ||
      entry.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      (entry.phone && entry.phone.includes(searchQuery)) ||
      entry.email.toLowerCase().includes(searchQuery.toLowerCase())

    // Apply party size filter
    let matchesPartySize = true
    if (partySizeFilter !== 'all') {
      const [minStr, maxStr] = partySizeFilter.split('-')
      if (!minStr) return false
      const min = parseInt(minStr)
      if (maxStr) {
        const max = parseInt(maxStr)
        matchesPartySize = entry.partySize >= min && entry.partySize <= max
      } else {
        // For "7+" case
        matchesPartySize = entry.partySize >= min
      )}
    )}

    // Apply status filter
    const matchesStatus = statusFilter === 'all' || entry.status === statusFilter

    // Apply table preference filter
    const matchesTablePreference = tablePreferenceFilter === 'all' ||
      (entry.tablePreference && entry.tablePreference === tablePreferenceFilter)

    return matchesSearch && matchesPartySize && matchesStatus && matchesTablePreference
  )}
)}

// Sort refs and functions
let sortBy = 'checkInTime'
let sortOrder = 'asc'

function toggleSort(field: 'name' | 'checkInTime' | 'estimatedWaitMinutes') {
  if (sortBy === field) {
    sortOrder = sortOrder === 'asc' ? 'desc' : 'asc'
  } else {
    sortBy = field
    sortOrder = 'asc'
  }
}

// Sort entries
function sortedEntries() {
  return [...filteredEntries].sort((a, b) => {
    if (sortBy === 'name') {
      return sortOrder === 'asc'
        ? a.name.localeCompare(b.name)
        : b.name.localeCompare(a.name)
    )}
    if (sortBy === 'checkInTime') {
      return sortOrder === 'asc'
        ? new Date(a.checkInTime).getTime() - new Date(b.checkInTime).getTime()
        : new Date(b.checkInTime).getTime() - new Date(a.checkInTime).getTime()
    )}
    if (sortBy === 'estimatedWaitMinutes') {
      return sortOrder === 'asc'
        ? a.estimatedWaitMinutes - b.estimatedWaitMinutes
        : b.estimatedWaitMinutes - a.estimatedWaitMinutes
    )}
    return 0
  )}
)}

// Pagination
const itemsPerPage = 10
let currentPage = 1

function paginatedEntries() {
  const start = (currentPage - 1) * itemsPerPage
  const end = start + itemsPerPage
  return sortedEntries.slice(start, end)
}

function totalPages() { return Math.ceil(sortedEntries.length / itemsPerPage) }

function nextPage() {
  if (currentPage < totalPages) {
    currentPage++
  }
}

function prevPage() {
  if (currentPage > 1) {
    currentPage--
  }
}

function goToPage(page: number) {
  if (page >= 1 && page <= totalPages) {
    currentPage = page
  }
}

// Get status badge class
const getStatusClass = (status: string): string => {
  switch (status) {
    case 'Waiting':
      return 'bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-600/20 dark:bg-blue-900/30 dark:text-blue-400'
    case 'Seated':
      return 'bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/30 dark:text-green-400'
    case 'Cancelled':
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
    case 'No Show':
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
    default:
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
  }
}

// Get priority class
const getPriorityClass = (priority: number): string => {
  switch (priority) {
    case 3:
      return 'text-red-600 dark:text-red-400 font-semibold'
    case 2:
      return 'text-yellow-600 dark:text-yellow-400'
    case 1:
      return 'text-blue-600 dark:text-blue-400'
    default:
      return 'text-gray-600 dark:text-neutral-400'
  }
}

// Modal state for adding/editing waitlist entry
let showEntryModal = false
let isEditMode = false
let currentEntry = null

// Calculate statistics
function totalEntries() { return waitlistEntries.length }
function waitingEntries() { return waitlistEntries.filter(e => e.status === 'Waiting' }.length)
function seatedEntries() { return waitlistEntries.filter(e => e.status === 'Seated' }.length)
function cancelledEntries() { return waitlistEntries.filter(e => e.status === 'Cancelled' }.length)
function noShowEntries() { return waitlistEntries.filter(e => e.status === 'No Show' }.length)

// Form state for entry fields
let entryName = ''
let entryEmail = ''
let entryPhone = ''
let entryPartySize = 2
let entryNotificationPreference = 'sms'
let entryTablePreference = null
let entrySpecialRequests = null
let entryNotes = ''
let entryPriority = 1

// Initialize form fields when opening modal
function openAddEntryModal(): void {
  isEditMode = false

  // Reset form fields
  entryName = ''
  entryEmail = ''
  entryPhone = ''
  entryPartySize = 2
  entryNotificationPreference = 'sms'
  entryTablePreference = null
  entrySpecialRequests = null
  entryNotes = ''
  entryPriority = 1

  showEntryModal = true
}

function openEditEntryModal(entry: WaitlistEntry): void {
  isEditMode = true
  currentEntry = { ...entry }

  // Set form fields from entry
  entryName = entry.name
  entryEmail = entry.email
  entryPhone = entry.phone
  entryPartySize = entry.partySize
  entryNotificationPreference = entry.notificationPreference
  entryTablePreference = entry.tablePreference
  entrySpecialRequests = entry.specialRequests
  entryNotes = entry.notes
  entryPriority = entry.priority

  showEntryModal = true
}

function saveEntry(): void {
  const now = new Date()
  const entry: WaitlistEntry = {
    id: isEditMode && currentEntry ? currentEntry.id : Math.max(0, ...waitlistEntries.map(e => e.id)) + 1,
    name: entryName,
    email: entryEmail,
    phone: entryPhone,
    partySize: entryPartySize,
    estimatedWaitMinutes: calculateEstimatedWait(entryPartySize),
    quotedWaitMinutes: Math.ceil(calculateEstimatedWait(entryPartySize) * 1.2), // Pad quote by 20%
    queuePosition: waitlistEntries.filter(e => e.status === 'Waiting').length + 1,
    notificationPreference: entryNotificationPreference,
    notes: entryNotes,
    status: 'Waiting',
    dateAdded: now.toISOString().split('T')[0],
    notified: false,
    priority: entryPriority,
    lastNotified: null,
    tablePreference: entryTablePreference,
    specialRequests: entrySpecialRequests,
    checkInTime: now.toISOString(),
    estimatedSeatingTime: null,
    actualSeatingTime: null
  }

  if (isEditMode && currentEntry) {
    // Update existing entry
    const index = waitlistEntries.findIndex(e => e.id === currentEntry.value!.id)
    if (index !== -1) {
      waitlistEntries[index] = entry
    }
  } else {
    // Add new entry
    waitlistEntries.push(entry)
  }

  // Update queue positions and wait times
  updateQueuePositions()

  // Send initial notification
  notifyCustomer(entry, `Thanks for joining the waitlist! Your estimated wait time is ${entry.quotedWaitMinutes} minutes. We'll notify you when your table is almost ready.`)

  showEntryModal = false
}

// Function to delete an entry
function deleteEntry(entryId: number): void {
  if (confirm('Are you sure you want to delete this waitlist entry?')) {
    const index = waitlistEntries.findIndex(e => e.id === entryId)
    if (index !== -1) {
      waitlistEntries.splice(index, 1)
    }
  }
}

// Function to mark an entry as seated
function markAsSeated(entryId: number): void {
  const entry = waitlistEntries.find(e => e.id === entryId)
  if (entry) {
    entry.status = 'Seated'
    entry.actualSeatingTime = new Date().toISOString()
    updateQueuePositions()
  }
}

// Function to mark an entry as no-show
function markAsNoShow(entryId: number): void {
  const entry = waitlistEntries.find(e => e.id === entryId)
  if (entry) {
    entry.status = 'No Show'
    updateQueuePositions()
  }
}

// Notification system
let showNotificationModal = false
let notificationSubject = ''
let notificationMessage = ''
let selectedEntries = []
let selectAll = false

// Toggle select all entries
function toggleSelectAll(): void {
  selectAll = !selectAll
  if (selectAll) {
    selectedEntries = paginatedEntries.map(entry => entry.id)
  } else {
    selectedEntries = []
  }
}

// Toggle selection of a single entry
function toggleEntrySelection(entryId: number): void {
  const index = selectedEntries.indexOf(entryId)
  if (index === -1) {
    selectedEntries.push(entryId)
  } else {
    selectedEntries.splice(index, 1)
  }

  // Update selectAll based on whether all entries are selected
  selectAll = paginatedEntries.length > 0 &&
    paginatedEntries.every(entry => selectedEntries.includes(entry.id))
}

// Open notification modal
function openNotificationModal(): void {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry to notify')
    return
  }

  notificationSubject = 'Product Now Available'
  notificationMessage = 'Good news! The product you were waiting for is now available for purchase.'
  showNotificationModal = true
}

// Send notifications to selected entries
function sendNotifications(): void {
  // In a real app, this would send actual emails or notifications
  waitlistEntries.forEach(entry => {
    if (selectedEntries.includes(entry.id)) {
      entry.notified = true
      entry.status = 'Seated'
    }
  }

  // Reset selection and close modal
  selectedEntries = []
  selectAll = false
  showNotificationModal = false

  // Show success message (in a real app, this would be a toast notification)
  alert(`Notifications sent to ${selectedEntries.length} customers`)
}

// Export waitlist data
function exportWaitlist(): void {
  // In a real app, this would generate a CSV or Excel file
  alert('Waitlist data exported successfully')
}

// Bulk actions
function bulkChangeStatus(status: string): void {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry')
    return
  }

  waitlistEntries.forEach(entry => {
    if (selectedEntries.includes(entry.id)) {
      entry.status = status
      if (status === 'Seated') {
        entry.notified = true
      }
    }
  }

  // Reset selection
  selectedEntries = []
  selectAll = false
}

// Bulk delete
function bulkDelete(): void {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry')
    return
  }

  if (confirm(`Are you sure you want to delete ${selectedEntries.length} waitlist entries?`)) {
    waitlistEntries = waitlistEntries.filter(entry => !selectedEntries.includes(entry.id))

    // Reset selection
    selectedEntries = []
    selectAll = false
  }
}

// Chart references
let productChartRef = null
let sourceChartRef = null
let statusChartRef = null
let trendChartRef = null

// Chart instances
let productChart: Chart | null = null
let sourceChart: Chart | null = null
let statusChart: Chart | null = null
let trendChart: Chart | null = null

// Generate random trend data for the past 30 days
const generateTrendData = () => {
  const data = []
  const today = new Date()
  for (let i = 29; i >= 0; i--) {
    const date = new Date(today)
    date.setDate(date.getDate() - i)
    data.push({
      date: date.toISOString().split('T')[0],
      count: Math.floor(Math.random() * 5) // Random number of entries per day (0-4)
    }
  }
  return data
}

let trendData = generateTrendData()

