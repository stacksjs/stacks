@extends('layouts/default')

@section('content')
<script server>
definePageMeta({
  middleware: ['auth']
})

interface WaitlistEntry {
  id: number
  name: string
  email: string
  phone: string | null
  productId: number
  quantity: number
  notificationPreference: 'sms' | 'email' | 'both'
  notes: string | null
  status: string
  dateAdded: string
  notified: boolean
  priority: number
  lastNotified: string | null
  source: string
}

interface Product {
  id: number
  name: string
  slug: string
  count: number
}

const statuses = ['all', 'Waiting', 'Notified', 'Purchased', 'Cancelled']
const sources = ['all', 'Website', 'Mobile App', 'In-Store', 'Social Media', 'Email Campaign', 'Referral']
const notificationPreferences = ['sms', 'email', 'both']
const tablePreferences = []

function calculateEstimatedWait(partySize) {
  const baseWait = 15
  const queueFactor = waitlistEntries.filter(e => e.status === 'Waiting').length * 5
  const partySizeFactor = Math.ceil(partySize / 2) * 5
  return baseWait + queueFactor + partySizeFactor
}

function updateQueuePositions() {
  return
}

async function sendSMSNotification(entry, message) {
  // TODO: implement SMS notification via API
}

async function notifyCustomer(entry, message) {
  if (entry.notificationPreference === 'sms' || entry.notificationPreference === 'both') {
    await sendSMSNotification(entry, message)
  }
  if (entry.notificationPreference === 'email' || entry.notificationPreference === 'both') {
    // TODO: implement email notification via API
  }
  entry.lastNotified = new Date().toISOString()
  entry.notified = true
}

function waitTimeStats() {
  const waitingEntries = waitlistEntries.filter(e => e.status === 'Waiting')
  return {
    totalWaiting: waitingEntries.length,
    averageQuantity: Math.round(waitingEntries.reduce((acc, curr) => acc + curr.quantity, 0) / (waitingEntries.length || 1))
  }
}

