function products() {
  const productMap = new Map()

  waitlistEntries.forEach(entry => {
    const count = productMap.get(entry.name) || 0
    productMap.set(entry.name, count + 1)
  }

  return Array.from(productMap.entries()).map(([name, count], index) => ({
    id: index + 1,
    name,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
    count
  }))
}

let searchQuery = ''
let statusFilter = 'all'
let partySizeFilter = 'all'
let tablePreferenceFilter = 'all'

function filteredEntries() {
  return waitlistEntries.filter(entry => {
    const matchesSearch = searchQuery === '' ||
      entry.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      (entry.phone && entry.phone.includes(searchQuery)) ||
      entry.email.toLowerCase().includes(searchQuery.toLowerCase())

    let matchesQuantity = true
    if (partySizeFilter !== 'all') {
      const [minStr, maxStr] = partySizeFilter.split('-')
      if (!minStr) return false
      const min = parseInt(minStr)
      if (maxStr) {
        const max = parseInt(maxStr)
        matchesQuantity = entry.quantity >= min && entry.quantity <= max
      } else {
        matchesQuantity = entry.quantity >= min
      )}
    )}

    const matchesStatus = statusFilter === 'all' || entry.status === statusFilter
    const matchesSource = sourceFilter === 'all' || entry.source === sourceFilter

    return matchesSearch && matchesQuantity && matchesStatus && matchesSource
  )}
)}

let sortBy = 'dateAdded'
let sortOrder = 'asc'

function toggleSort(field) {
  if (sortBy === field) {
    sortOrder = sortOrder === 'asc' ? 'desc' : 'asc'
  } else {
    sortBy = field
    sortOrder = 'asc'
  }
}

function sortedEntries() {
  return [...filteredEntries].sort((a, b) => {
    if (sortBy === 'name') {
      return sortOrder === 'asc'
        ? a.name.localeCompare(b.name)
        : b.name.localeCompare(a.name)
    )}
    if (sortBy === 'dateAdded') {
      return sortOrder === 'asc'
        ? new Date(a.dateAdded).getTime() - new Date(b.dateAdded).getTime()
        : new Date(b.dateAdded).getTime() - new Date(a.dateAdded).getTime()
    )}
    if (sortBy === 'quantity') {
      return sortOrder === 'asc'
        ? a.quantity - b.quantity
        : b.quantity - a.quantity
    )}
    return 0
  )}
)}

const itemsPerPage = 10
let currentPage = 1

function paginatedEntries() {
  const start = (currentPage - 1) * itemsPerPage
  const end = start + itemsPerPage
  return sortedEntries.slice(start, end)
}

function totalPages() { return Math.ceil(sortedEntries.length / itemsPerPage) }

function nextPage() {
  if (currentPage < totalPages) {
    currentPage++
  }
}

function prevPage() {
  if (currentPage > 1) {
    currentPage--
  }
}

function goToPage(page) {
  if (page >= 1 && page <= totalPages) {
    currentPage = page
  }
}

const getStatusClass = (status) => {
  switch (status) {
    case 'Waiting':
      return 'bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-600/20 dark:bg-blue-900/30 dark:text-blue-400'
    case 'Notified':
      return 'bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/30 dark:text-green-400'
    case 'Purchased':
      return 'bg-purple-50 text-purple-700 ring-1 ring-inset ring-purple-600/20 dark:bg-purple-900/30 dark:text-purple-400'
    case 'Cancelled':
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
    default:
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
  }
}

const getPriorityClass = (priority) => {
  switch (priority) {
    case 3:
      return 'text-red-600 dark:text-red-400 font-semibold'
    case 2:
      return 'text-yellow-600 dark:text-yellow-400'
    case 1:
      return 'text-blue-600 dark:text-blue-400'
    default:
      return 'text-gray-600 dark:text-neutral-400'
  }
}

let showEntryModal = false
let isEditMode = false
let currentEntry = null

function totalEntries() { return waitlistEntries.length }
function waitingEntries() { return waitlistEntries.filter(e => e.status === 'Waiting' }.length)
function notifiedEntries() { return waitlistEntries.filter(e => e.status === 'Notified' }.length)
function purchasedEntries() { return waitlistEntries.filter(e => e.status === 'Purchased' }.length)
function conversionRate() {
  const total = totalEntries
  const purchased = purchasedEntries
  return total > 0 ? Math.round((purchased / total) * 100) : 0
}

let entryName = ''
let entryEmail = ''
let entryPhone = null
let entryQuantity = 2
let entryNotificationPreference = 'sms'
let entrySource = 'Website'
let entryNotes = null
let entryPriority = 1

let sourceFilter = 'all'

function openAddEntryModal() {
  isEditMode = false

  entryName = ''
  entryEmail = ''
  entryPhone = ''
  entryQuantity = 2
  entryNotificationPreference = 'sms'
  entrySource = 'Website'
  entryNotes = ''
  entryPriority = 1

  showEntryModal = true
}

function openEditEntryModal(entry) {
  isEditMode = true
  currentEntry = { ...entry }

  entryName = entry.name
  entryEmail = entry.email
  entryPhone = entry.phone
  entryQuantity = entry.quantity
  entryNotificationPreference = entry.notificationPreference
  entrySource = entry.source
  entryNotes = entry.notes
  entryPriority = entry.priority

  showEntryModal = true
}

function saveEntry() {
  const now = new Date()
  const formattedDate = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`
  const entry = {
    id: isEditMode && currentEntry ? currentEntry.id : Math.max(0, ...waitlistEntries.map(e => e.id)) + 1,
    name: entryName,
    email: entryEmail,
    phone: entryPhone || null,
    productId: Math.floor(Math.random() * 1000),
    quantity: entryQuantity,
    notificationPreference: entryNotificationPreference,
    notes: entryNotes || null,
    status: 'Waiting',
    dateAdded: formattedDate,
    notified: false,
    priority: entryPriority,
    lastNotified: null,
    source: entrySource
  }

  if (isEditMode && currentEntry) {
    const index = waitlistEntries.findIndex(e => e.id === currentEntry.id)
    if (index !== -1) {
      waitlistEntries[index] = entry
    }
  } else {
    waitlistEntries.push(entry)
  }

  notifyCustomer(entry, `Thanks for joining the waitlist! We'll notify you when the product becomes available.`)
  showEntryModal = false
}

function deleteEntry(entryId) {
  if (confirm('Are you sure you want to delete this waitlist entry?')) {
    const index = waitlistEntries.findIndex(e => e.id === entryId)
    if (index !== -1) {
      waitlistEntries.splice(index, 1)
    }
  }
}

function markAsNotified(entryId) {
  const entry = waitlistEntries.find(e => e.id === entryId)
  if (entry) {
    entry.status = 'Notified'
  }
}

function markAsPurchased(entryId) {
  const entry = waitlistEntries.find(e => e.id === entryId)
  if (entry) {
    entry.status = 'Purchased'
  }
}

let showNotificationModal = false
let notificationSubject = 'Product Now Available'
let notificationMessage = 'Good news! The product you were waiting for is now available for purchase.'
let selectedEntries = []
let selectAll = false

function toggleSelectAll() {
  selectAll = !selectAll
  if (selectAll) {
    selectedEntries = paginatedEntries.map(entry => entry.id)
  } else {
    selectedEntries = []
  }
}

function toggleEntrySelection(entryId) {
  const index = selectedEntries.indexOf(entryId)
  if (index === -1) {
    selectedEntries.push(entryId)
  } else {
    selectedEntries.splice(index, 1)
  }

  selectAll = paginatedEntries.length > 0 &&
    paginatedEntries.every(entry => selectedEntries.includes(entry.id))
}

function openNotificationModal() {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry to notify')
    return
  }

  notificationSubject = 'Product Now Available'
  notificationMessage = 'Good news! The product you were waiting for is now available for purchase.'
  showNotificationModal = true
}

function sendNotifications() {
  waitlistEntries.forEach(entry => {
    if (selectedEntries.includes(entry.id)) {
      entry.notified = true
      entry.status = 'Notified'
    }
  }

  selectedEntries = []
  selectAll = false
  showNotificationModal = false

  alert(`Notifications sent to ${selectedEntries.length} customers`)
}

function exportWaitlist() {
  alert('Waitlist data exported successfully')
}

function bulkChangeStatus(status) {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry')
    return
  }

  waitlistEntries.forEach(entry => {
    if (selectedEntries.includes(entry.id)) {
      entry.status = status
      if (status === 'Notified') {
        entry.notified = true
      }
    }
  }

  selectedEntries = []
  selectAll = false
}

function bulkDelete() {
  if (selectedEntries.length === 0) {
    alert('Please select at least one waitlist entry')
    return
  }

  if (confirm(`Are you sure you want to delete ${selectedEntries.length} waitlist entries?`)) {
    waitlistEntries = waitlistEntries.filter(entry => !selectedEntries.includes(entry.id))

    selectedEntries = []
    selectAll = false
  }
}

let productChartRef = null
let sourceChartRef = null
let statusChartRef = null
let trendChartRef = null

let productChart = null
let sourceChart = null
let statusChart = null
let trendChart = null

const generateTrendData = () => {
  const data = []
  const today = new Date()
  for (let i = 29; i >= 0; i--) {
    const date = new Date(today)
    date.setDate(date.getDate() - i)
    data.push({
      date: date.toISOString().split('T')[0],
      count: Math.floor(Math.random() * 5)
    }
  }
  return data
}

let trendData = generateTrendData()

const chartColors = {
  blue: {
    fill: 'rgba(59, 130, 246, 0.2)',
    stroke: 'rgba(59, 130, 246, 1)',
    point: 'rgba(59, 130, 246, 1)',
  },
  green: {
    fill: 'rgba(16, 185, 129, 0.2)',
    stroke: 'rgba(16, 185, 129, 1)',
    point: 'rgba(16, 185, 129, 1)',
  },
  purple: {
    fill: 'rgba(139, 92, 246, 0.2)',
    stroke: 'rgba(139, 92, 246, 1)',
    point: 'rgba(139, 92, 246, 1)',
  },
  yellow: {
    fill: 'rgba(245, 158, 11, 0.2)',
    stroke: 'rgba(245, 158, 11, 1)',
    point: 'rgba(245, 158, 11, 1)',
  },
  red: {
    fill: 'rgba(239, 68, 68, 0.2)',
    stroke: 'rgba(239, 68, 68, 1)',
    point: 'rgba(239, 68, 68, 1)',
  },
}

const baseChartOptions = {
  responsive: true,
  maintainAspectRatio: false,
  plugins: {
    legend: {
      display: true,
      position: 'bottom',
      labels: {
        usePointStyle: true,
        padding: 20,
        font: {
          size: 12
        }
      }
    },
    title: {
      display: true,
      font: {
        size: 16,
        weight: 'bold'
      },
      padding: {
        top: 10,
        bottom: 20
      }
    }
  }
}

const baseChartOptionsWithScales = {
  ...baseChartOptions,
  scales: {
    y: {
      beginAtZero: true,
      grid: {
        display: true,
        color: 'rgba(0, 0, 0, 0.05)',
      },
      ticks: {
        precision: 0
      }
    },
    x: {
      grid: {
        display: false
      }
    }
  }
}

function initProductChart() {
  if (!productChartRef) return

  const ctx = productChartRef.getContext('2d')
  if (!ctx) return

  const partySizes = [1, 2, 3, 4, 5, 6, '7+']
  const partySizeCounts = partySizes.map(size => {
    if (size === '7+') {
      return waitlistEntries.filter(entry => entry.quantity >= 7).length
    }
    return waitlistEntries.filter(entry => entry.quantity === size).length
  }

  const gradient = ctx.createLinearGradient(0, 0, 0, 400)
  gradient.addColorStop(0, chartColors.blue.fill)
  gradient.addColorStop(1, 'rgba(59, 130, 246, 0.05)')

  productChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: partySizes.map(size => `${size} ${size === 1 ? 'unit' : 'units'}`),
      datasets: [{
        label: 'Number of Orders',
        data: partySizeCounts,
        backgroundColor: gradient,
        borderColor: chartColors.blue.stroke,
        borderWidth: 2,
        borderRadius: 6,
        maxBarThickness: 60,
        barPercentage: 0.7
      }]
    },
    options: {
      ...baseChartOptionsWithScales,
      plugins: {
        legend: {
          display: false
        },
        title: {
          display: false
        }
      }
    }
  }
}

function initSourceChart() {
  if (!sourceChartRef) return

  const ctx = sourceChartRef.getContext('2d')
  if (!ctx) return

  const sourceLabels = sources.slice(1)
  const sourceCounts = sourceLabels.map(source =>
    waitlistEntries.filter(entry =>
      entry.source ? entry.source === source : false
    ).length
  )

  sourceChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: sourceLabels,
      datasets: [{
        data: sourceCounts,
        backgroundColor: [
          chartColors.blue.fill,
          chartColors.green.fill,
          chartColors.purple.fill,
          chartColors.yellow.fill,
          chartColors.red.fill
        ],
        borderColor: [
          chartColors.blue.stroke,
          chartColors.green.stroke,
          chartColors.purple.stroke,
          chartColors.yellow.stroke,
          chartColors.red.stroke
        ],
        borderWidth: 2,
        hoverOffset: 4,
        spacing: 2
      }]
    },
    options: {
      ...baseChartOptions,
      cutout: '75%',
      scales: {
        x: { display: false },
        y: { display: false }
      },
      plugins: {
        legend: {
          position: 'right',
          labels: {
            usePointStyle: true,
            padding: 20,
            font: {
              size: 11
            }
          }
        },
        title: {
          display: false
        }
      }
    }
  }
}

function initTrendChart() {
  if (!trendChartRef) return

  const ctx = trendChartRef.getContext('2d')
  if (!ctx) return

  const gradient = ctx.createLinearGradient(0, 0, 0, 400)
  gradient.addColorStop(0, chartColors.blue.fill)
  gradient.addColorStop(1, 'rgba(59, 130, 246, 0)')

  trendChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: trendData.map(d => d.date),
      datasets: [{
        label: 'New Waitlist Entries',
        data: trendData.map(d => d.count),
        backgroundColor: gradient,
        borderColor: chartColors.blue.stroke,
        borderWidth: 2,
        pointBackgroundColor: chartColors.blue.point,
        pointBorderColor: '#fff',
        pointHoverBackgroundColor: '#fff',
        pointHoverBorderColor: chartColors.blue.stroke,
        tension: 0.4,
        fill: true,
        pointRadius: 4,
        pointHoverRadius: 6
      }]
    },
    options: {
      ...baseChartOptionsWithScales,
      plugins: {
        legend: {
          display: false
        },
        title: {
          display: false
        }
      },
      scales: {
        x: {
          grid: {
            display: false
          },
          ticks: {
            maxRotation: 0,
            autoSkip: true,
            maxTicksLimit: 7
          }
        },
        y: {
          beginAtZero: true,
          grid: {
            color: 'rgba(0, 0, 0, 0.05)',
          },
          ticks: {
            precision: 0,
            maxTicksLimit: 5
          }
        }
      }
    }
  }
}

function initStatusChart() {
  if (!statusChartRef) return

  const ctx = statusChartRef.getContext('2d')
  if (!ctx) return

  const statusLabels = statuses.slice(1)
  const statusData = statusLabels.map(status =>
    waitlistEntries.filter(entry => entry.status === status).length
  )

  statusChart = new Chart(ctx, {
    type: 'pie',
    data: {
      labels: statusLabels,
      datasets: [{
        data: statusData,
        backgroundColor: [
          chartColors.blue.fill,
          chartColors.green.fill,
          chartColors.purple.fill,
          chartColors.red.fill
        ],
        borderColor: [
          chartColors.blue.stroke,
          chartColors.green.stroke,
          chartColors.purple.stroke,
          chartColors.red.stroke
        ],
        borderWidth: 2,
        hoverOffset: 4,
        spacing: 2
      }]
    },
    options: {
      ...baseChartOptions,
      scales: {
        x: { display: false },
        y: { display: false }
      },
      plugins: {
        legend: {
          position: 'right',
          labels: {
            usePointStyle: true,
            padding: 20,
            font: {
              size: 11
            }
          }
        },
        title: {
          display: false
        }
      }
    }
  }
}

function updateCharts() {
  if (productChart && productChart.data) {
    const chart = productChart
    const partySizes = [1, 2, 3, 4, 5, 6, '7+']
    const partySizeCounts = partySizes.map(size => {
      if (size === '7+') {
        return waitlistEntries.filter(entry => entry.quantity >= 7).length
      }
      return waitlistEntries.filter(entry => entry.quantity === size).length
    }

    chart.data.labels = partySizes.map(size => `${size} ${size === 1 ? 'unit' : 'units'}`)
    if (chart.data.datasets?.[0]) {
      chart.data.datasets[0].data = partySizeCounts
    }
    chart.update()
  }

  if (sourceChart && sourceChart.data) {
    const chart = sourceChart
    const sourceLabels = sources.slice(1)
    chart.data.labels = sourceLabels
    if (chart.data.datasets?.[0]) {
      chart.data.datasets[0].data = sourceLabels.map(source =>
        waitlistEntries.filter(entry =>
          entry.source ? entry.source === source : false
        ).length
      )
    }
    chart.update()
  }

  if (statusChart && statusChart.data) {
    const chart = statusChart
    const statusLabels = statuses.slice(1)
    chart.data.labels = statusLabels
    if (chart.data.datasets?.[0]) {
      chart.data.datasets[0].data = statusLabels.map(status =>
        waitlistEntries.filter(entry => entry.status === status).length
      )
    }
    chart.update()
  }

  if (trendChart && trendChart.data) {
    const chart = trendChart
    const dates = trendData.map(d => d.date)
    chart.data.labels = dates
    if (chart.data.datasets?.[0]) {
      chart.data.datasets[0].data = trendData.map(d => d.count)
    }
    chart.update()
  }
}

</script>

@title('Dashboard - Marketing Waitlist')
<main>
