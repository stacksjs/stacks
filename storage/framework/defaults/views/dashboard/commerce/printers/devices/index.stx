<script client>

interface Printer {
  id: number
  username: string
  macAddress: string
  location: string
  terminal: string
  status: 'Online' | 'Offline' | 'Warning'
  lastPing: string
  printCount: number
  errorCount: number
}

const initialPrinters: Printer[] = [
  { id: 1, username: 'Checkout-1', macAddress: '00:1B:44:11:3A:B7', location: 'Main Floor', terminal: 'POS-1', status: 'Online', lastPing: '2 mins ago', printCount: 1245, errorCount: 3 },
  { id: 2, username: 'Checkout-2', macAddress: '00:1B:44:11:3A:C8', location: 'Main Floor', terminal: 'POS-2', status: 'Online', lastPing: '1 min ago', printCount: 987, errorCount: 0 },
  { id: 3, username: 'Kitchen-1', macAddress: '00:1B:44:11:3B:D9', location: 'Kitchen', terminal: 'KDS-1', status: 'Offline', lastPing: '3 hours ago', printCount: 876, errorCount: 12 },
  { id: 4, username: 'Checkout-3', macAddress: '00:1B:44:11:3C:E0', location: 'Second Floor', terminal: 'POS-3', status: 'Online', lastPing: '5 mins ago', printCount: 765, errorCount: 1 },
  { id: 5, username: 'Pickup-1', macAddress: '00:1B:44:11:3D:F1', location: 'Pickup Area', terminal: 'POS-4', status: 'Warning', lastPing: '10 mins ago', printCount: 654, errorCount: 5 },
  { id: 6, username: 'Checkout-4', macAddress: '00:1B:44:11:3E:02', location: 'Main Floor', terminal: 'POS-5', status: 'Online', lastPing: '3 mins ago', printCount: 543, errorCount: 0 },
  { id: 7, username: 'Kitchen-2', macAddress: '00:1B:44:11:3F:13', location: 'Kitchen', terminal: 'KDS-2', status: 'Online', lastPing: '4 mins ago', printCount: 432, errorCount: 2 },
]

const printers = state(initialPrinters)
const locationFilter = state<string>('All Locations')
const statusFilter = state<string>('All Statuses')

const filteredPrinters = derived(() => {
  const lFilter = locationFilter()
  const sFilter = statusFilter()
  return printers().filter(p =>
    (lFilter === 'All Locations' || p.location === lFilter)
    && (sFilter === 'All Statuses' || p.status === sFilter),
  )
})

const totalPrinters = derived(() => printers().length)
const onlinePrinters = derived(() => printers().filter(p => p.status === 'Online').length)
const offlinePrinters = derived(() => printers().filter(p => p.status === 'Offline').length)
const warningPrinters = derived(() => printers().filter(p => p.status === 'Warning').length)
const totalPrints = derived(() => printers().reduce((sum, p) => sum + p.printCount, 0))
const totalErrors = derived(() => printers().reduce((sum, p) => sum + p.errorCount, 0))
const errorRate = derived(() => totalPrints() > 0 ? ((totalErrors() / totalPrints()) * 100).toFixed(2) : '0.00')
const healthPercent = derived(() => totalPrinters() > 0 ? Math.round((onlinePrinters() / totalPrinters()) * 100) : 0)
const allHealthy = derived(() => onlinePrinters() === totalPrinters() && totalPrinters() > 0)

function statusBadgeClass(status: string): string {
  switch (status) {
    case 'Online': return 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
    case 'Offline': return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300'
    case 'Warning': return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300'
    default: return 'bg-gray-100 text-gray-800 dark:bg-neutral-700 dark:text-neutral-300'
  }
}

const statusData = {
  labels: ['Online', 'Offline', 'Warning'],
  datasets: [{ backgroundColor: ['#10B981', '#EF4444', '#F59E0B'], data: [5, 1, 1] }],
}

const printVolumeData = {
  labels: ['Checkout-1', 'Checkout-2', 'Kitchen-1', 'Checkout-3', 'Pickup-1', 'Checkout-4', 'Kitchen-2'],
  datasets: [{ label: 'Print Count', backgroundColor: 'rgba(59, 130, 246, 0.8)', data: [1245, 987, 876, 765, 654, 543, 432] }],
}

const errorRateData = {
  labels: ['Checkout-1', 'Checkout-2', 'Kitchen-1', 'Checkout-3', 'Pickup-1', 'Checkout-4', 'Kitchen-2'],
  datasets: [{ label: 'Error Count', backgroundColor: 'rgba(239, 68, 68, 0.8)', data: [3, 0, 12, 1, 5, 0, 2] }],
}

const chartOptions = {
  responsive: true,
  maintainAspectRatio: false,
  plugins: { legend: { display: true, position: 'bottom' } },
}

const barChartOptions = {
  responsive: true,
  maintainAspectRatio: false,
  plugins: { legend: { display: false } },
  scales: {
    y: { beginAtZero: true, grid: { display: true, color: 'rgba(0, 0, 0, 0.05)' } },
    x: { grid: { display: false } },
  },
}

const { Chart, registerables } = await import('@stacksjs/charts')
Chart.register(...registerables)

const { destroyAll } = useCharts([
  { Chart, id: 'chart_1', type: 'pie', data: statusData, options: chartOptions },
  { Chart, id: 'chart_2', type: 'bar', data: printVolumeData, options: barChartOptions },
  { Chart, id: 'chart_3', type: 'bar', data: errorRateData, options: barChartOptions },
])

onDestroy(() => {
  destroyAll()
})
</script>

@endsection
