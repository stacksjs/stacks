// Define menu item type
interface MenuItem {
  id: number
  name: string
  description: string
  price: number
  salePrice: number | null
  category: string
  tags: string[]
  imageUrl: string
  available: boolean
  featured: boolean
  rating: number
  reviewCount: number
  preparationTime: string
  allergies: string[]
}

// Define category type
interface Category {
  id: number
  name: string
  slug: string
  count: number
}

// Define order type
interface OrderItem {
  menuItemId: number
  name: string
  price: number
  quantity: number
  specialInstructions: string
  modifiers: string[]
}

interface Order {
  id: number
  tableNumber: number
  items: OrderItem[]
  status: 'new' | 'in-progress' | 'ready' | 'served' | 'paid'
  createdAt: string
  totalAmount: number
}

