    preparationTime: '0 min',
    allergies: ['dairy', 'gluten']
  }
])

// Categories derived from menu items
const categories = computed<Category[]>(() => {
  const categoryMap = new Map<string, number>()

  menuItems.forEach(item => {
    const count = categoryMap.get(item.category) || 0
    categoryMap.set(item.category, count + 1)
  }

  return Array.from(categoryMap.entries()).map(([name, count], index) => ({
    id: index + 1,
    name,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
    count
  }))
}

// Current table number
let tableNumber = 1
const availableTables = Array.from({ length: 20 }, (_, i) => i + 1)

// Filter and sort options
let searchQuery = ''
let categoryFilter = 'all'
let viewMode = 'grid' // Default to grid view for better imagery

// Computed filtered and sorted menu items
function filteredMenuItems() {
  return menuItems
    .filter(item => {
      // Apply search filter
      const matchesSearch =
        item.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
        item.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
        item.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()))

      // Apply category filter
      const matchesCategory = categoryFilter === 'all' || item.category === categoryFilter

      return matchesSearch && matchesCategory
    })
}

// Current order
const currentOrder = reactive<Order>({
  id: 1,
  tableNumber: 1,
  items: [],
  status: 'new',
  createdAt: new Date().toISOString(),
  totalAmount: 0
}

// Add item to order
function addToOrder(menuItem: MenuItem, quantity = 1): void {
  const existingItem = currentOrder.items.find(item => item.menuItemId === menuItem.id)

  if (existingItem) {
    existingItem.quantity += quantity
  } else {
    currentOrder.items.push({
      menuItemId: menuItem.id,
      name: menuItem.name,
      price: menuItem.salePrice !== null ? menuItem.salePrice : menuItem.price,
      quantity,
      specialInstructions: '',
      modifiers: []
    }
  }

  updateOrderTotal()
}

// Remove item from order
function removeFromOrder(index: number): void {
  currentOrder.items.splice(index, 1)
  updateOrderTotal()
}

// Update item quantity
function updateItemQuantity(index: number, quantity: number): void {
  if (quantity <= 0) {
    removeFromOrder(index)
    return
  }

  const item = currentOrder.items[index]
  if (item) {
    item.quantity = quantity
    updateOrderTotal()
  }
}

// Update order total
function updateOrderTotal(): void {
  currentOrder.totalAmount = currentOrder.items.reduce((total, item) => {
    return total + (item.price * item.quantity)
  }, 0)
}

// Special instructions modal
let showSpecialInstructionsModal = false
let currentEditingItemIndex = -1
let tempSpecialInstructions = ''

function openSpecialInstructionsModal(index: number): void {
  const item = currentOrder.items[index]
  if (item) {
    currentEditingItemIndex = index
    tempSpecialInstructions = item.specialInstructions
    showSpecialInstructionsModal = true
  }
}

function saveSpecialInstructions(): void {
  if (currentEditingItemIndex >= 0) {
    const item = currentOrder.items[currentEditingItemIndex]
    if (item) {
      item.specialInstructions = tempSpecialInstructions
    }
  }
  showSpecialInstructionsModal = false
}

// Place order functionality
let orderPlaced = false
let orderSummary = null

function placeOrder(): void {
  if (currentOrder.items.length === 0) {
    alert('Please add items to your order')
    return
  }

  // Update order status
  currentOrder.tableNumber = tableNumber
  currentOrder.status = 'new'
  currentOrder.createdAt = new Date().toISOString()

  // Save a copy of the current order for summary display
  orderSummary = JSON.parse(JSON.stringify(currentOrder)) as Order

  // Show order confirmation
  orderPlaced = true

  // Reset order for a new one
  setTimeout(() => {
    currentOrder.items = []
    currentOrder.totalAmount = 0
    currentOrder.id++
    orderPlaced = false
    orderSummary = null
  }, 10000) // Reset after 10 seconds
}

// Table selection
function selectTable(table: number): void {
  tableNumber = table
}

// Get allergy tag class
const getAllergyClass = (allergy: string): string => {
  switch (allergy) {
    case 'dairy':
      return 'bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-600/20 dark:bg-blue-900/30 dark:text-blue-400'
    case 'gluten':
      return 'bg-yellow-50 text-yellow-700 ring-1 ring-inset ring-yellow-600/20 dark:bg-yellow-900/30 dark:text-yellow-400'
    case 'egg':
      return 'bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/30 dark:text-green-400'
    case 'soy':
      return 'bg-purple-50 text-purple-700 ring-1 ring-inset ring-purple-600/20 dark:bg-purple-900/30 dark:text-purple-400'
    case 'nuts':
      return 'bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20 dark:bg-red-900/30 dark:text-red-400'
    default:
      return 'bg-gray-50 text-gray-700 ring-1 ring-inset ring-gray-600/20 dark:bg-neutral-900/30 dark:text-neutral-400'
  }
}

// Add the scrollToOrder function to the script
function scrollToOrder(): void {
  const orderElement = document.getElementById('order-section')
  if (orderElement) {
    orderElement.scrollIntoView({ behavior: 'smooth' })
  }
}
</script>

@title('Self-Service Menu')
<main>
  <div class="px-6 py-6 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <!-- Header section -->
      <div class="sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="font-semibold text-2xl text-gray-900 dark:text-white">Self-Service Menu</h1>
          <p class="mt-2 text-gray-700 text-sm dark:text-neutral-300">
            Device {{ tableNumber }} - Browse and order directly from your device
          </p>
        </div>
        <div class="flex gap-4 items-center mt-4 sm:mt-0">
          <!-- Device selection dropdown -->
          <div>
            <label for="table-select" class="sr-only">Select Device</label>
            <select
              id="table-select"
              value="{{ tableNumber }}"
              onchange="selectTable(tableNumber)"
              class="block pl-3 pr-10 py-1.5 text-gray-900 sm:leading-6 sm:text-sm dark:text-white dark:bg-neutral-800 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-700 focus:ring-2 focus:ring-blue-600 focus:ring-inset"
            >
              @foreach(availableTables as table)
                <option value="{{ table }}">
                  Device {{ table }}
                </option>
              @endforeach
            </select>
          </div>

          <!-- View cart button -->
          <button
            type="button"
            onclick="scrollToOrder"
            class="inline-flex relative items-center px-3 py-2 font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-blue-600 focus-visible:outline-offset-2 shadow-sm"
          >
            <div class="mr-1 h-5 w-5 i-hugeicons-shopping-cart-02"></div>
            View Receipt
            @if(currentOrder.items.length > 0)
              <span
                class="flex absolute items-center justify-center h-5 w-5 font-bold text-white text-xs bg-red-600 rounded-full -right-2 -top-2"
              >
                {{ currentOrder.items.length }}
              </span>
            @endif
          </button>
        </div>
      </div>

      <!-- Summary cards -->
      <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 mt-6">
        <!-- Total products card -->
        <div class="overflow-hidden bg-white dark:bg-neutral-800 rounded-lg shadow">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="p-2 h-10 w-10 bg-blue-100 dark:bg-blue-900 rounded-md">
                  <div class="h-6 w-6 text-blue-600 dark:text-blue-300 i-hugeicons-package"></div>
                </div>
              </div>
              <div class="flex-1 ml-5 w-0">
                <dl>
                  <dt class="font-medium text-gray-500 text-sm truncate dark:text-neutral-400">Total Items</dt>
                  <dd>
                    <div class="font-medium text-gray-900 text-lg dark:text-white">{{ menuItems.length }}</div>
                  </dd>
                </dl>
              </div>
            </div>
          </div>
        </div>

        <!-- Device selection card -->
        <div class="overflow-hidden bg-white dark:bg-neutral-800 rounded-lg shadow">
          <div class="p-5">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="p-2 h-10 w-10 bg-yellow-100 dark:bg-yellow-900 rounded-md">
                  <div class="h-6 w-6 text-yellow-600 dark:text-yellow-300 i-hugeicons-tablet"></div>
                </div>
              </div>
              <div class="flex-1 ml-5 w-0">
                <dl>
                  <dt class="font-medium text-gray-500 text-sm truncate dark:text-neutral-400">Device</dt>
                  <dd>
                    <div class="font-medium text-gray-900 text-lg dark:text-white">{{ tableNumber }}</div>
                  </dd>
                </dl>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Category navigation -->
      <div class="overflow-x-auto mt-6 pb-2">
        <div class="inline-flex space-x-2">
          <button
            onclick="categoryFilter = 'all'"
            class="px-4 py-2 font-medium text-sm rounded-full transition"
            class="text-gray-800 text-white' dark:text-white dark:bg-neutral-700 hover:bg-gray-200 dark:hover:bg-neutral-600' : ? 'all' 'bg-blue-600 'bg-gray-100 {{ }} === categoryFilter"
          >
            All
          </button>
          @foreach(categories as category)
            <button
              onclick="categoryFilter = category.name"
              class="px-4 py-2 font-medium text-sm rounded-full transition"
              class="text-gray-800 text-white' dark:text-white dark:bg-neutral-700 hover:bg-gray-200 dark:hover:bg-neutral-600' : ? 'bg-blue-600 'bg-gray-100 {{ }} === category.name categoryFilter"
            >
              {{ category.name }}
            </button>
          @endforeach
        </div>
      </div>

      <!-- Search bar -->
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mt-4">
        <div class="relative max-w-sm">
          <div class="flex absolute inset-y-0 left-0 items-center pl-3 pointer-events-none">
            <div class="h-5 w-5 text-gray-400 i-hugeicons-search-01"></div>
          </div>
          <input
            value="{{ searchQuery }}"
            type="text"
            class="block pl-10 pr-3 py-1.5 w-full text-gray-900 sm:leading-6 sm:text-sm dark:text-white placeholder:text-gray-400 dark:placeholder:text-neutral-500 dark:bg-neutral-800 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-700 focus:ring-2 focus:ring-blue-600 focus:ring-inset"
            placeholder="Search menu..."
          />
        </div>

        <!-- View mode toggle -->
        <div class="flex rounded-md shadow-sm">
          <button
            type="button"
            onclick="viewMode = 'grid'"
            class="[
              'relative inline-flex items-center rounded-l-md px-3 py-2 text-sm font-semibold ring-1 ring-inset focus:z-10',
              viewMode === 'grid'
                ? 'bg-blue-600 text-white ring-blue-600'
                : 'bg-white text-gray-900 ring-gray-300 hover:bg-gray-50 dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:hover:bg-neutral-700'
            ] {{ }}"
          >
            <div class="h-5 w-5 i-hugeicons-grid"></div>
          </button>
          <button
            type="button"
            onclick="viewMode = 'list'"
            class="[
              'relative -ml-px inline-flex items-center rounded-r-md px-3 py-2 text-sm font-semibold ring-1 ring-inset focus:z-10',
              viewMode === 'list'
                ? 'bg-blue-600 text-white ring-blue-600'
                : 'bg-white text-gray-900 ring-gray-300 hover:bg-gray-50 dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:hover:bg-neutral-700'
            ] {{ }}"
          >
            <div class="h-5 w-5 i-hugeicons-right-to-left-list-number"></div>
          </button>
        </div>
      </div>

      <!-- Menu items grid view -->
      @if(viewMode === 'grid')
        <div class="mt-6">
          @if(filteredMenuItems.length === 0)
            <div class="py-12 text-center">
              <div class="mx-auto h-12 w-12 text-gray-400 i-hugeicons-box-01"></div>
              <h3 class="mt-2 font-semibold text-gray-900 text-sm dark:text-white">No menu items found</h3>
              <p class="mt-1 text-gray-500 text-sm dark:text-neutral-400">Try adjusting your search or category filter.</p>
            </div>
          @else
            <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              <!-- Menu item card -->
              @foreach(filteredMenuItems as item)
                <div
                  class="overflow-hidden relative bg-white dark:bg-neutral-800 border border-gray-200 rounded-lg dark:border-neutral-700 shadow-sm hover:shadow-md transition group"
                  class="!item.available 'opacity-70': { {{ } }}"
                >
                  <!-- Item image with badges -->
                  <div class="aspect-square overflow-hidden relative bg-gray-200 dark:bg-neutral-700">
                    <img
                      :src="item.imageUrl"
                      :alt="item.name"
                      class="object-cover h-full w-full duration-300 transition-transform group-hover:scale-105"
                    />
                    @if(!item.available)
                      <span
                        class="absolute right-2 top-2 px-2 py-0.5 font-medium text-red-700 text-xs dark:text-red-400 bg-red-50 dark:bg-red-900/30 ring-1 ring-inset ring-red-600/20 rounded-full"
                      >
                        Unavailable
                      </span>
                    @endif
                    @if(item.featured)
                      <span
                        class="absolute left-2 top-2 px-2 py-0.5 font-medium text-xs text-yellow-700 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/30 ring-1 ring-inset ring-yellow-600/20 rounded-full"
                      >
                        Popular
                      </span>
                    @endif
                  </div>

                  <!-- Item info -->
                  <div class="p-4">
                    <div class="flex items-center justify-between">
                      <h3 class="font-medium text-gray-900 text-sm dark:text-white">{{ item.name }}</h3>
                      <div class="flex items-center">
                        <div class="h-4 w-4 text-yellow-400 i-hugeicons-star"></div>
                        <span class="ml-1 text-gray-600 text-sm dark:text-neutral-400">{{ item.rating }}</span>
                      </div>
                    </div>

