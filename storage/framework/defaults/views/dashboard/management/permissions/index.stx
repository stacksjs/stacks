  <div class="mt-8">
    <div class="overflow-hidden bg-white dark:bg-neutral-800 rounded-lg shadow">
      <div class="flex items-center justify-between px-4 py-5 sm:px-6">
        <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white">Roles</h3>
        <Button variant="primary" @click="addRole()">Add Role</Button>
      </div>
      <div class="border-gray-200 border-t dark:border-neutral-700">
        <table class="min-w-full divide-gray-200 divide-y dark:divide-neutral-700">
          <thead class="bg-gray-50 dark:bg-neutral-700">
            <tr>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-left text-xs tracking-wider uppercase dark:text-neutral-300">Role Name</th>
