        <div class="flex items-center space-x-4">
          <div class="flex items-center space-x-2">
            <label for="permission-filter" class="text-gray-500 text-sm dark:text-neutral-400">Filter:</label>
            <input id="permission-filter" x-model="permissionFilter" type="text" placeholder="Search permissions..." class="pl-3 pr-3 py-1.5 w-64 text-gray-900 sm:leading-6 sm:text-sm dark:text-white dark:bg-neutral-800 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-700 focus:ring-2 focus:ring-blue-600" />
          </div>
          <Button variant="primary" @click="addPermission()">Add Permission</Button>
        </div>
      </div>
      <div class="border-gray-200 border-t dark:border-neutral-700">
        <table class="min-w-full divide-gray-200 divide-y dark:divide-neutral-700">
          <thead class="bg-gray-50 dark:bg-neutral-700">
            <tr>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-left text-xs tracking-wider uppercase dark:text-neutral-300">ID</th>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-left text-xs tracking-wider uppercase dark:text-neutral-300">Name</th>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-left text-xs tracking-wider uppercase dark:text-neutral-300">Description</th>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-left text-xs tracking-wider uppercase dark:text-neutral-300">Created</th>
              <th scope="col" class="px-6 py-3 font-medium text-gray-500 text-right text-xs tracking-wider uppercase dark:text-neutral-300">Actions</th>
