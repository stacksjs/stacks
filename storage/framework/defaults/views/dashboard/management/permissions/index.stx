      <dd class="mt-1 font-semibold text-3xl text-gray-900 tracking-tight dark:text-white">95</dd>
      <dd class="flex items-center mt-2 text-green-600 text-sm dark:text-green-400">
        <div class="mr-1 h-4 w-4 i-hugeicons-analytics-up"></div>
        <span>8.3% increase</span>
      </dd>
    </div>

    <div class="overflow-hidden px-4 py-5 sm:p-6 bg-white dark:bg-neutral-800 rounded-lg shadow">
      <dt class="font-medium text-gray-500 text-sm truncate dark:text-neutral-300">Permission Changes</dt>
      <dd class="mt-1 font-semibold text-3xl text-gray-900 tracking-tight dark:text-white">145</dd>
      <dd class="flex items-center mt-2 text-red-600 text-sm dark:text-red-400">
        <div class="mr-1 h-4 w-4 i-hugeicons-analytics-down"></div>
        <span>5.2% decrease</span>
      </dd>
    </div>
  </dl>

  <div class="grid gap-5 grid-cols-1 lg:grid-cols-2 mt-8">
    <div class="overflow-hidden bg-white dark:bg-neutral-800 rounded-lg shadow">
      <div class="p-6">
        <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white">Permissions by Role</h3>
        <div class="mt-2 h-80">
          <canvas id="permissions_by_role_chart"></canvas>
