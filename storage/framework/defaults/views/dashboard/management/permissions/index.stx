            @foreach(rolesList() as role)
              <tr>
                <td class="px-6 py-4 font-medium text-gray-900 text-sm whitespace-nowrap dark:text-white">{{ role.name }}</td>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ role.description }}</td>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ role.users }}</td>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ role.lastUpdated }}</td>
                <td class="px-6 py-4 font-medium text-right text-sm whitespace-nowrap">
                  <button @click="editRole({{ role.id }})" class="mr-3 text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300">Edit</button>
                  <button @click="deleteRole({{ role.id }})" class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300">Delete</button>
                </td>
              </tr>
            @endforeach
