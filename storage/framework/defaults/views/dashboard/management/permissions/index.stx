          <tbody class="bg-white dark:bg-neutral-800 divide-gray-200 divide-y dark:divide-neutral-700">
            @foreach(filteredPermissions() as permission)
              <tr>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ permission.id }}</td>
                <td class="px-6 py-4 font-medium text-gray-900 text-sm whitespace-nowrap dark:text-white">{{ permission.name }}</td>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ permission.description }}</td>
                <td class="px-6 py-4 text-gray-500 text-sm whitespace-nowrap dark:text-neutral-300">{{ permission.created_at }}</td>
                <td class="px-6 py-4 font-medium text-right text-sm whitespace-nowrap">
