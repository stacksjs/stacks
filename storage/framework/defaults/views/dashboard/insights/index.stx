  },
  {
    type: 'Illuminate\\Http\\Client\\RequestException',
    location: 'app/Actions/FlightAction.ts:91',
    count: 22,
    latest: '5 minutes ago',
  },
]

let cache = {
  hits: 1675,
  misses: 284,
  hitRate: 85.5,
  keys: [
    {
      name: 'flight:2',
      hits: 137,
      misses: 14,
      hitRate: 90.73,
      lastAccessed: '2 minutes ago',
      ttl: 3600
    },
    {
      name: 'flight:3',
      hits: 132,
      misses: 15,
