</PageLayout>
<script client>

interface ChartLike { destroy: () => void }
type ChartCtor = new (canvas: HTMLElement, config: { type: string, data: unknown, options?: unknown }) => ChartLike

const dateRangeDisplay = state('All Time: Sep 7, 2023 to Mar 6, 2025')
const comparisonType = state('no-comparison')

const marketingData = state<Array<{ date: string, spend: number, revenue: number }>>([
  { date: '2023-11-01', spend: 5000, revenue: 15000 },
  { date: '2023-12-01', spend: 6000, revenue: 18000 },
  { date: '2024-01-01', spend: 7000, revenue: 21000 },
  { date: '2024-02-01', spend: 8000, revenue: 24000 },
  { date: '2024-03-01', spend: 10000, revenue: 30000 },
  { date: '2024-04-01', spend: 9000, revenue: 27000 },
  { date: '2024-05-01', spend: 8000, revenue: 24000 },
  { date: '2024-06-01', spend: 7000, revenue: 21000 },
  { date: '2024-07-01', spend: 8000, revenue: 24000 },
  { date: '2024-08-01', spend: 7000, revenue: 21000 },
  { date: '2024-09-01', spend: 7000, revenue: 21000 },
  { date: '2024-10-01', spend: 8000, revenue: 24000 },
  { date: '2024-11-01', spend: 6000, revenue: 18000 },
  { date: '2024-12-01', spend: 12000, revenue: 36000 },
  { date: '2025-01-01', spend: 7000, revenue: 21000 },
  { date: '2025-02-01', spend: 5000, revenue: 15000 },
])

let chartHandle: { destroy: () => void } | null = null

onMount(async () => {
  const { Chart, registerables } = await import('@stacksjs/charts')
  Chart.register(...registerables)
  const Ctor = Chart as unknown as ChartCtor

  chartHandle = useChart({
    Chart: Ctor,
    id: 'marketing_chart',
    type: 'line',
    data: {
      labels: marketingData().map(item => item.date),
      datasets: [
        { label: 'Revenue ($)', data: marketingData().map(item => item.revenue), backgroundColor: 'rgba(16, 185, 129, 0.3)', borderColor: 'rgba(16, 185, 129, 0.8)', borderWidth: 2, tension: 0.4, fill: true, yAxisID: 'y' },
        { label: 'Spend ($)', data: marketingData().map(item => item.spend), backgroundColor: 'rgba(244, 63, 94, 0.1)', borderColor: 'rgba(244, 63, 94, 0.8)', borderWidth: 2, tension: 0.4, fill: false, yAxisID: 'y' },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 4 } },
        y: { type: 'linear', display: true, position: 'left', beginAtZero: true, grid: { borderDash: [2, 4], color: 'rgba(160, 174, 192, 0.2)' }, ticks: { maxTicksLimit: 6, callback: (value: number | string) => `$${Number(value).toLocaleString()}` } },
      },
      plugins: {
        legend: { display: true, position: 'top' },
        tooltip: {
          mode: 'index',
          intersect: false,
          callbacks: {
            label(context: { dataset: { label?: string }, parsed: { y: number } }) {
              let label = context.dataset.label || ''
              if (label)
                label += ': '
              label += `$${context.parsed.y.toLocaleString()}`
              return label
            },
          },
        },
      },
    },
  })
})

onDestroy(() => {
  chartHandle?.destroy()
  chartHandle = null
})
</script>

<style scoped>
.commerce-marketing {
  @apply space-y-6;
}
</style>

@endsection
