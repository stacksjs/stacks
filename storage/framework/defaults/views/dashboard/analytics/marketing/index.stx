@section('content')
<script server>
const campaignsRaw = [
  { name: 'Summer Sale 2024', id: 'SUMMER24', spend: 25000, revenue: 75000, roi: 200, conversions: 1500 },
  { name: 'New Product Launch', id: 'NEWPROD', spend: 20000, revenue: 60000, roi: 200, conversions: 1200 },
  { name: 'Holiday Special', id: 'HOLIDAY', spend: 18000, revenue: 54000, roi: 200, conversions: 1080 },
  { name: 'Back to School', id: 'SCHOOL', spend: 15000, revenue: 45000, roi: 200, conversions: 900 },
  { name: 'Flash Sale', id: 'FLASH', spend: 12000, revenue: 36000, roi: 200, conversions: 720 },
  { name: 'Loyalty Program', id: 'LOYALTY', spend: 10000, revenue: 30000, roi: 200, conversions: 600 },
  { name: 'Referral Program', id: 'REFERRAL', spend: 8000, revenue: 24000, roi: 200, conversions: 480 },
  { name: 'Email Newsletter', id: 'EMAIL', spend: 7000, revenue: 21000, roi: 200, conversions: 420 },
  { name: 'Retargeting Campaign', id: 'RETARGET', spend: 6000, revenue: 18000, roi: 200, conversions: 360 },
  { name: 'Social Media Contest', id: 'CONTEST', spend: 4000, revenue: 12000, roi: 200, conversions: 240 },
]

const channelsRaw = [
  { name: 'Paid Search', spend: 35000, revenue: 105000, roi: 200, conversions: 2100 },
  { name: 'Social Media', spend: 30000, revenue: 90000, roi: 200, conversions: 1800 },
  { name: 'Email Marketing', spend: 20000, revenue: 60000, roi: 200, conversions: 1200 },
  { name: 'Display Ads', spend: 15000, revenue: 45000, roi: 200, conversions: 900 },
  { name: 'Affiliate Marketing', spend: 10000, revenue: 30000, roi: 200, conversions: 600 },
  { name: 'Influencer Marketing', spend: 8000, revenue: 24000, roi: 200, conversions: 480 },
  { name: 'Content Marketing', spend: 5000, revenue: 15000, roi: 200, conversions: 300 },
  { name: 'SMS Marketing', spend: 2000, revenue: 6000, roi: 200, conversions: 120 },
]

const adsRaw = [
  { name: 'Summer Sale Banner', id: 'AD-001', impressions: 250000, clicks: 12500, ctr: 5, conversions: 625, cpa: 16 },
  { name: 'Product Showcase Video', id: 'AD-002', impressions: 200000, clicks: 10000, ctr: 5, conversions: 500, cpa: 16 },
  { name: 'Limited Time Offer', id: 'AD-003', impressions: 180000, clicks: 9000, ctr: 5, conversions: 450, cpa: 16 },
  { name: 'Customer Testimonial', id: 'AD-004', impressions: 150000, clicks: 7500, ctr: 5, conversions: 375, cpa: 16 },
  { name: 'Free Shipping Promo', id: 'AD-005', impressions: 120000, clicks: 6000, ctr: 5, conversions: 300, cpa: 16 },
]

const totalCampaignRevenue = campaignsRaw.reduce((s, c) => s + c.revenue, 0)
const totalChannelRevenue = channelsRaw.reduce((s, c) => s + c.revenue, 0)
const totalAdConversions = adsRaw.reduce((s, a) => s + a.conversions, 0)

const campaignsData = campaignsRaw.map(c => ({ ...c, percentage: Math.round((c.revenue / totalCampaignRevenue) * 100) }))
const channelsData = channelsRaw.map(c => ({ ...c, percentage: Math.round((c.revenue / totalChannelRevenue) * 100) }))
const adsData = adsRaw.map(a => ({ ...a, percentage: Math.round((a.conversions / totalAdConversions) * 100) }))

const marketingOverview = {
  roi: 200,
  cpa: 16.67,
  conversionRate: '3.2%',
}

function formatNumber(n) {
  return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',')
}

function formatCurrency(amount) {
  return `$${amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
}
</script>

@title('Dashboard - Commerce Marketing Analytics')
