                    <button
                      onclick="confirmDeleteEvent(event)"
                      class="text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300"
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
              @endforeach
            </tbody>
          </table>
        </div>
      </div>
      @endif

      <!-- Event Details Modal -->
      @if(showEventDetails)
      <div class="fixed inset-0 overflow-y-auto z-10">
        <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
          <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeEventDetails"></div>

          <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-3xl sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
            <div class="absolute right-0 top-0 pr-4 pt-4">
              <button
                type="button"
                class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300 bg-white dark:bg-neutral-800 rounded-md focus:outline-none"
                onclick="closeEventDetails"
              >
                <span class="sr-only">Close</span>
                <div class="h-6 w-6 i-hugeicons-cancel-01"></div>
              </button>
            </div>

            @if(selectedEvent)
            <div>
              <div class="mb-6">
                <h3 class="font-semibold text-gray-900 text-xl dark:text-white">
                  {{ selectedEvent.name }}
                </h3>
                <p class="mt-1 text-gray-500 text-sm dark:text-neutral-400">
                  Created on {{ formatDate(selectedEvent.createdAt) }}
                </p>
              </div>

              <!-- Event Stats -->
              <div class="grid gap-4 grid-cols-1 sm:grid-cols-3 mb-6">
                <div class="p-4 bg-gray-50 dark:bg-neutral-700 rounded-lg">
                  <div class="text-gray-500 text-sm dark:text-neutral-400">Completions</div>
                  <div class="font-bold text-2xl text-gray-900 dark:text-white">{{ formatNumber(selectedEvent.completions) }}</div>
