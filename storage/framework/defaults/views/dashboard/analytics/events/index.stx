                </div>
                <div class="h-64 w-full">
                  <canvas id="eventChart"></canvas>
                </div>
              </div>

              <!-- Event Code Examples -->
              <div class="mb-6">
                <h4 class="mb-2 font-medium text-gray-900 text-md dark:text-white">Implementation Code</h4>

                <div class="overflow-x-auto p-4 text-white bg-gray-800 rounded-lg">
                  <pre class="text-sm"><code>// Basic event tracking
stacks.trackEvent('{{ selectedEvent.name }}');

// With value (for e-commerce)
stacks.trackEvent('{{ selectedEvent.name }}', {
  _value: 1000, // Value in cents
});</code></pre>
                </div>
              </div>

              <div class="flex justify-end mt-6">
                <button
                  type="button"
                  class="inline-flex justify-center mr-2 px-3 py-2 font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
                  onclick="closeEventDetails"
                >
                  Close
                </button>
                <button
                  type="button"
                  class="inline-flex justify-center px-3 py-2 font-semibold text-sm text-white bg-red-600 hover:bg-red-500 rounded-md shadow-sm"
                  onclick="confirmDeleteEvent(selectedEvent)"
                >
                  Delete Event
                </button>
              </div>
            </div>
            @endif
          </div>
        </div>
      </div>
      @endif

      <!-- Create Event Modal -->
      @if(showCreateEventModal)
      <div class="fixed inset-0 overflow-y-auto z-10">
        <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
          <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeCreateEventModal"></div>

          <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
            <div class="absolute right-0 top-0 pr-4 pt-4">
              <button
                type="button"
                class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300 bg-white dark:bg-neutral-800 rounded-md focus:outline-none"
                onclick="closeCreateEventModal"
              >
                <span class="sr-only">Close</span>
                <div class="h-6 w-6 i-hugeicons-cancel-01"></div>
              </button>
            </div>

            <div>
              <div class="mb-6">
                <h3 class="font-semibold text-gray-900 text-xl dark:text-white">
                  Create New Event
                </h3>
                <p class="mt-1 text-gray-500 text-sm dark:text-neutral-400">
                  Set up a new event to track conversions on your site
                </p>
              </div>

              <form onsubmit="createNewEvent; return false">
                <div class="mb-4">
                  <label for="eventName" class="block mb-1 font-medium text-gray-700 text-sm dark:text-neutral-300">
                    Event Name
                  </label>
                  <input
                    type="text"
                    id="eventName"
                    value="{{ newEvent.name }}"
                    class="block py-1.5 w-full text-gray-900 sm:leading-6 sm:text-sm dark:text-white placeholder:text-gray-400 dark:bg-neutral-700 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 focus:ring-2 focus:ring-blue-600 focus:ring-inset shadow-sm"
                    placeholder="e.g., Newsletter Signup"
                    required
                  />
                  <p class="mt-1 text-gray-500 text-xs dark:text-neutral-400">
                    Use a descriptive name without special characters or emojis
                  </p>
                </div>

                <div class="mb-4">
                  <div class="flex items-center">
                    <input
                      id="hasValue"
                      type="checkbox"
                      value="{{ newEvent.hasValue }}"
                      class="h-4 w-4 text-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-500"
                    />
                    <label for="hasValue" class="block ml-2 text-gray-700 text-sm dark:text-neutral-300">
                      This event has a monetary value (e.g., purchase)
                    </label>
                  </div>
                </div>

                @if(newEvent.hasValue)
                <div class="mb-6">
                  <label for="currency" class="block mb-1 font-medium text-gray-700 text-sm dark:text-neutral-300">
                    Currency
                  </label>
                  <select
                    id="currency"
                    value="{{ newEvent.currency }}"
                    class="block py-1.5 w-full text-gray-900 sm:leading-6 sm:text-sm dark:text-white dark:bg-neutral-700 border-0 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 focus:ring-2 focus:ring-blue-600 focus:ring-inset shadow-sm"
                  >
                    <option value="USD">USD - US Dollar</option>
                    <option value="EUR">EUR - Euro</option>
                    <option value="GBP">GBP - British Pound</option>
                    <option value="CAD">CAD - Canadian Dollar</option>
                    <option value="AUD">AUD - Australian Dollar</option>
                  </select>
                </div>
                @endif

                <div class="flex justify-end mt-6">
                  <button
                    type="button"
                    class="inline-flex justify-center mr-2 px-3 py-2 font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
                    onclick="closeCreateEventModal"
                  >
                    Cancel
                  </button>
                  <button
                    type="submit"
                    class="inline-flex justify-center px-3 py-2 font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md shadow-sm"
                    disabled="{{ !newEvent.name }}"
                  >
                    Create Event
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
      @endif

      <!-- Delete Confirmation Modal -->
      @if(showDeleteConfirmModal)
      <div class="fixed inset-0 overflow-y-auto z-10">
        <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
          <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="cancelDeleteEvent"></div>

          <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
            <div>
              <div class="mb-6">
                <div class="flex items-center justify-center mx-auto h-12 w-12 bg-red-100 dark:bg-red-900 rounded-full">
                  <div class="h-6 w-6 text-red-600 dark:text-red-400 i-hugeicons-alert-02"></div>
                </div>
                <div class="mt-3 sm:mt-5 text-center">
                  <h3 class="font-semibold text-gray-900 text-xl dark:text-white">
                    {{ eventToDelete?.status === 'active' ? 'Block Event' : 'Delete Event' }}
                  </h3>
                  <div class="mt-2">
                    <p class="text-gray-500 text-sm dark:text-neutral-400">
                      {{ eventToDelete?.status === 'active'
                        ? `Are you sure you want to block "${eventToDelete?.name}"? This will prevent data collection for this event in the future.`
                        : `Are you sure you want to permanently delete "${eventToDelete?.name}"? This action cannot be undone.`
                      }}
                    </p>
                  </div>
                </div>
              </div>

              <div class="flex justify-end mt-6">
                <button
                  type="button"
                  class="inline-flex justify-center mr-2 px-3 py-2 font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
                  onclick="cancelDeleteEvent"
                >
                  Cancel
                </button>
                <button
                  type="button"
                  class="inline-flex justify-center px-3 py-2 font-semibold text-sm text-white bg-red-600 hover:bg-red-500 rounded-md shadow-sm"
                  onclick="deleteEvent"
                >
                  {{ eventToDelete?.status === 'active' ? 'Block Event' : 'Delete Event' }}
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      @endif
    </div>
  </div>
</main>
<script client>
const { Chart, registerables } = await import('chart.js/auto')
Chart.register(...registerables)

let eventChart = null

function createEventChart(eventId) {
  const ctx = document.getElementById('eventChart')
  if (!ctx) return

  const chartData = eventChartData[eventId] || []
  const datasets = [{
    label: 'Completions',
    data: chartData.map(item => item.completions),
    backgroundColor: 'rgba(59, 130, 246, 0.3)',
    borderColor: 'rgba(59, 130, 246, 0.8)',
    borderWidth: 2,
    tension: 0.4,
    fill: true
  }]

  if (isComparing && comparisonData[eventId]) {
    datasets.push({
      label: comparisonLabel,
      data: chartData.map(item => Math.round(item.completions * (0.6 + Math.random() * 0.2))),
      backgroundColor: 'rgba(156, 163, 175, 0.2)',
      borderColor: 'rgba(156, 163, 175, 0.7)',
      borderWidth: 2,
      borderDash: [5, 5],
      tension: 0.4,
      fill: false
    })
  }

  if (eventChart) {
    eventChart.destroy()
  }

  eventChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: chartData.map(item => {
        const date = new Date(item.date)
        return `${date.getMonth() + 1}/${date.getDate()}`
      }),
      datasets
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      scales: { x: { grid: { display: false } }, y: { beginAtZero: true, grid: { borderDash: [2, 4], color: 'rgba(160, 174, 192, 0.2)' }, ticks: { precision: 0 } } },
      plugins: { legend: { display: isComparing, position: 'top' }, tooltip: { mode: 'index', intersect: false } }
    }
  })
}

updateDataForDateRange()
</script>


@endsection
