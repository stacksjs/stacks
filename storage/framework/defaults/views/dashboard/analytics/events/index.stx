                  <div class="mt-1 text-sm" :class="getPercentageChangeClass(comparisonData[selectedEvent.id].percentageChange.completions)">
                    {{ formatPercentageChange(comparisonData[selectedEvent.id].percentageChange.completions) }} {{ comparisonLabel }}
                  </div>
                  @endif
                </div>

                <div class="p-4 bg-gray-50 dark:bg-neutral-700 rounded-lg">
                  <div class="text-gray-500 text-sm dark:text-neutral-400">Conversion Rate</div>
                  <div class="font-bold text-2xl text-gray-900 dark:text-white">{{ selectedEvent.conversionRate }}%</div>
                  @if(isComparing && comparisonData[selectedEvent.id])
                  <div class="mt-1 text-sm" :class="getPercentageChangeClass(comparisonData[selectedEvent.id].percentageChange.conversionRate)">
                    {{ formatPercentageChange(comparisonData[selectedEvent.id].percentageChange.conversionRate) }} {{ comparisonLabel }}
                  </div>
                  @endif
                </div>

                <div class="p-4 bg-gray-50 dark:bg-neutral-700 rounded-lg">
                  <div class="text-gray-500 text-sm dark:text-neutral-400">Value</div>
                  <div class="font-bold text-2xl text-gray-900 dark:text-white">{{ formatCurrency(selectedEvent) }}</div>
                  @if(isComparing && comparisonData[selectedEvent.id] && selectedEvent > 0)
                  <div class="mt-1 text-sm" :class="getPercentageChangeClass(comparisonData[selectedEvent.id].percentageChange)">
                    {{ formatPercentageChange(comparisonData[selectedEvent.id].percentageChange) }} {{ comparisonLabel }}
                  </div>
                  @endif
                </div>
              </div>

              <!-- Event Chart -->
              <div class="mb-6 p-4 bg-white dark:bg-neutral-700 rounded-lg shadow">
                <div class="flex items-center justify-between mb-2">
