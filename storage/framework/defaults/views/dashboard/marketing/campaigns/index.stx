                          <div class="sm:col-span-6">
                            <!-- ... rest of the existing template ... -->
                          </div>

                          <!-- Submit Button -->
                          <div class="sm:grid sm:gap-3 sm:grid-cols-2 sm:grid-flow-row-dense mt-12 sm:mt-12">
                            <button
                              type="submit"
                              class="inline-flex justify-center sm:col-start-2 px-4 py-2 w-full font-medium text-base text-white sm:text-sm bg-blue-600 dark:bg-blue-700 hover:bg-blue-700 dark:hover:bg-blue-600 border border-transparent rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
                            >
                              {{ isEditMode ? 'Save Changes' : 'Create Campaign' }}
                            </button>
                            <button
                              type="button"
                              onclick="showCampaignModal = false"
                              class="inline-flex justify-center sm:col-start-1 mt-3 px-4 py-2 sm:mt-0 w-full font-medium text-base text-gray-700 sm:text-sm dark:text-neutral-200 bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 border border-gray-300 rounded-md dark:border-neutral-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm"
                            >
                              Cancel
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>


@endsection
