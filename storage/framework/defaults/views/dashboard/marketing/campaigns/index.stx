function openEditCampaignModal(campaign: Campaign): void {
  currentCampaign = { ...campaign }
  isEditMode = true
  showCampaignModal = true
}

function closeCampaignModal(): void {
  showCampaignModal = false
}

// Add scheduling state
let isScheduled = false
let scheduleDate = ''
let scheduleTime = ''

// Update save campaign to handle scheduling
const saveCampaign = () => {
  if (!currentCampaign) return;

  const today = new Date().toISOString().split('T')[0];
  if (!today) return;

  // Handle scheduling
  if (isScheduled && scheduleDate && scheduleTime) {
    const scheduledDateTime = `${scheduleDate} ${scheduleTime}:00`;
    currentCampaign.scheduled_at = scheduledDateTime;
  } else {
    currentCampaign.scheduled_at = null;
  }

  currentCampaign.lastModified = today;

  if (isEditMode) {
    const index = campaigns.findIndex(c => c.id === currentCampaign.value?.id);
    if (index !== -1) {
      campaigns[index] = { ...currentCampaign };
    }
  } else {
    campaigns.push({ ...currentCampaign });
  }

  showCampaignModal = false;
};

// Delete campaign
function deleteCampaign(campaignId: number): void {
  const index = campaigns.findIndex(c => c.id === campaignId)
  if (index !== -1) {
    campaigns.splice(index, 1)
  }
}

// Update SMS character count
const updateSmsCharacterCount = () => {
  if (currentCampaign && currentCampaign.smsContent) {
    currentCampaign.smsCharacterCount = currentCampaign.smsContent.length;
  } else if (currentCampaign) {
    currentCampaign.smsCharacterCount = 0;
  }
};

// Calculate summary statistics
function totalActiveCampaigns() { return campaigns.filter(c => c.status === 'Active' }.length)
function totalScheduledCampaigns() { return campaigns.filter(c => c.status === 'Scheduled' }.length)
// Define empty placeholders for totalBudget and totalSpent to avoid template errors
function totalBudget() { return 0 }
function totalSpent() { return 0 }

// Calculate campaign type metrics
function totalEmailCampaigns() { return campaigns.filter(c => c.type === 'Email' }.length)
function totalSmsCampaigns() { return campaigns.filter(c => c.type === 'SMS' }.length)
// Commenting out other campaign types as we're focusing only on email and SMS
// function totalSocialMediaCampaigns() { return campaigns.filter(c => c.type === 'Social Media' }.length)

// Get campaign type icon
