              <div class="h-4 w-4 i-hugeicons-copy"></div>
            </button>
            <button @click="openEditCampaignModal(campaign.id)" class="px-2.5 py-1.5 text-sm text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-md" title="Edit">
              <div class="h-4 w-4 i-hugeicons-edit-01"></div>
            </button>
            <button @click="deleteCampaign(campaign.id)" class="px-2.5 py-1.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-md" title="Delete">
              <div class="h-4 w-4 i-hugeicons-waste"></div>
            </button>
          </div>
