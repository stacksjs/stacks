              </div>
            </div>
            @endforeach
          </div>
          @endif
        </div>
        @endif

        <!-- Pagination -->
        @if(totalPages > 1)
        <div class="flex items-center justify-between mt-6 px-4 py-3 sm:px-6 border-gray-200 border-t dark:border-neutral-700">
          <div class="flex sm:hidden flex-1 justify-between">
            <button
              onclick="previousPage"
              disabled="{{ currentPage === 1 }}"
              class="[
                'relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 dark:border-neutral-600 dark:bg-neutral-800 dark:text-white',
                currentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-gray-50 dark:hover:bg-neutral-700'
              ] {{ }}"
            >
              Previous
            </button>
            <button
              onclick="nextPage"
              disabled="{{ currentPage === totalPages }}"
              class="[
                'relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 dark:border-neutral-600 dark:bg-neutral-800 dark:text-white',
                currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : 'hover:bg-gray-50 dark:hover:bg-neutral-700'
              ] {{ }}"
            >
              Next
            </button>
          </div>
          <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
              <p class="text-gray-700 text-sm dark:text-neutral-300">
                Showing <span class="font-medium">{{ (currentPage - 1) * itemsPerPage + 1 }}</span> to
                <span class="font-medium">{{ Math.min(currentPage * itemsPerPage, filteredLists.length) }}</span> of
                <span class="font-medium">{{ filteredLists.length }}</span> results
              </p>
            </div>
            <div>
              <nav class="inline-flex -space-x-px rounded-md shadow-sm isolate" aria-label="Pagination">
                <button
                  onclick="previousPage"
                  disabled="{{ currentPage === 1 }}"
                  class="inline-flex relative focus:z-20 items-center px-2 py-2 text-gray-400 dark:text-neutral-500 hover:bg-gray-50 dark:hover:bg-neutral-700 ring-1 ring-gray-300 ring-inset rounded-l-md dark:ring-neutral-600 focus:outline-offset-0"
                  class="'opacity-50 { {{ } }} === 1 currentPage cursor-not-allowed':"
                >
                  <span class="sr-only">Previous</span>
                  <div class="h-5 w-5 i-hugeicons-arrow-left-01"></div>
                </button>
                @foreach(totalPages as page)
                <button
                  onclick="changePage(page)"
                  class="[
                    'relative inline-flex items-center px-4 py-2 text-sm font-semibold ring-1 ring-inset ring-gray-300 focus:z-20 focus:outline-offset-0 dark:ring-neutral-600',
                    page === currentPage
                      ? 'bg-blue-600 text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:bg-blue-700'
                      : 'text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-neutral-700'
                  ] {{ }}"
                >
                  {{ page }}
                </button>
                @endforeach
                <button
                  onclick="nextPage"
                  disabled="{{ currentPage === totalPages }}"
                  class="inline-flex relative focus:z-20 items-center px-2 py-2 text-gray-400 dark:text-neutral-500 hover:bg-gray-50 dark:hover:bg-neutral-700 ring-1 ring-gray-300 ring-inset rounded-r-md dark:ring-neutral-600 focus:outline-offset-0"
                  class="'opacity-50 { {{ } }} === currentPage cursor-not-allowed': totalPages"
                >
                  <span class="sr-only">Next</span>
                  <div class="h-5 w-5 i-hugeicons-arrow-right-01"></div>
                </button>
              </nav>
            </div>
          </div>
        </div>
        @endif
      </div>
    </div>

    <!-- Add/Edit List Modal -->
    @if(showListModal)
    <div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-neutral-900 dark:bg-opacity-75 transition-opacity"></div>

        <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
          <div class="absolute right-0 top-0 pr-4 pt-4">
            <button
              type="button"
              onclick="closeListModal"
              class="text-gray-400 dark:text-neutral-500 hover:text-gray-500 dark:hover:text-gray-400 bg-white dark:bg-neutral-800 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              <span class="sr-only">Close</span>
              <div class="h-6 w-6 i-hugeicons-can"></div>
            </button>
          </div>
          <div class="sm:flex sm:items-start">
            <div class="mt-3 sm:ml-4 sm:mt-0 w-full text-center sm:text-left">
              <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white">
                {{ isEditMode ? 'Edit List' : 'Create New List' }}
              </h3>
              <div class="mt-4">
                <form onsubmit="saveList; return false" class="space-y-4">
                  <!-- List name -->
                  <div>
                    <label for="list-name" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Name</label>
                    <input
                      type="text"
                      id="list-name"
                      value="{{ listName }}"
                      class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-700 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                      required
                    />
                  </div>

                  <!-- List description -->
                  <div>
                    <label for="list-description" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Description</label>
                    <textarea
                      id="list-description"
                      value="{{ listDescription }}"
                      rows="3"
                      class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-700 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                    ></textarea>
                  </div>

                  <!-- List type -->
                  <div>
                    <label for="list-type" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Type</label>
                    <select
                      id="list-type"
                      value="{{ listType }}"
                      class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-700 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                    >
                      <option value="email">Email Only</option>
                      <option value="sms">SMS Only</option>
                      <option value="both">Email & SMS</option>
                    </select>
                  </div>

                  <!-- List tags -->
                  <div>
                    <label for="list-tags" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Tags (comma separated)</label>
                    <input
                      type="text"
                      id="list-tags"
                      value="{{ listTags }}"
                      class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-700 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                      placeholder="newsletter, promo, vip"
                    />
                  </div>

                  <!-- List status -->
                  <div>
                    <label for="list-status" class="block font-medium text-gray-700 text-sm dark:text-neutral-300">Status</label>
                    <select
                      id="list-status"
                      value="{{ listStatus }}"
                      class="block mt-1 w-full sm:text-sm dark:text-white dark:bg-neutral-700 border-gray-300 rounded-md dark:border-neutral-600 focus:border-blue-500 focus:ring-blue-500 shadow-sm"
                    >
                      <option value="Active">Active</option>
                      <option value="Draft">Draft</option>
                      <option value="Archived">Archived</option>
                    </select>
                  </div>

                  <!-- Default list checkbox -->
                  <div class="mt-4">
                    <div class="flex items-center">
                      <input
                        id="list-default"
                        type="checkbox"
                        value="{{ listIsDefault }}"
                        class="h-4 w-4 text-blue-600 border-gray-300 rounded dark:border-neutral-600 focus:ring-blue-500"
                      />
                      <label for="list-default" class="block ml-2 font-medium text-gray-700 text-sm dark:text-neutral-300">Set as default list</label>
                    </div>
                    @if(listIsDefault)
                    <p class="mt-1 text-gray-500 text-xs dark:text-neutral-400">
                      This will unset any other default list. New subscribers will be added to this list by default.
                    </p>
                    @endif
                  </div>

                  <div class="sm:flex sm:flex-row-reverse mt-5 sm:mt-4">
                    <button
                      type="submit"
                      class="inline-flex justify-center px-3 py-2 sm:ml-3 w-full sm:w-auto font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md shadow-sm"
                    >
                      {{ isEditMode ? 'Save Changes' : 'Create List' }}
                    </button>
                    <button
                      type="button"
                      onclick="closeListModal"
                      class="inline-flex justify-center mt-3 px-3 py-2 sm:mt-0 w-full sm:w-auto font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
                    >
                      Cancel
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    @endif

    <!-- Import Subscribers Modal -->
    @if(showImportModal)
    <div class="fixed inset-0 overflow-y-auto z-10">
      <div class="flex items-end justify-center sm:items-center p-4 sm:p-0 min-h-full text-center">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-neutral-900 dark:bg-opacity-75 transition-opacity"></div>

        <div class="overflow-hidden relative pb-4 pt-5 px-4 sm:my-8 sm:p-6 sm:max-w-lg sm:w-full text-left bg-white dark:bg-neutral-800 rounded-lg shadow-xl transition-all transform">
          <div class="absolute right-0 top-0 pr-4 pt-4">
            <button
              type="button"
              onclick="closeImportModal"
              class="text-gray-400 dark:text-neutral-500 hover:text-gray-500 dark:hover:text-gray-400 bg-white dark:bg-neutral-800 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
            >
              <span class="sr-only">Close</span>
              <div class="h-6 w-6 i-hugeicons-can"></div>
            </button>
          </div>
          <div class="sm:flex sm:items-start">
            <div class="flex flex-shrink-0 items-center justify-center mx-auto sm:mx-0 h-12 w-12 sm:h-10 sm:w-10 bg-blue-100 dark:bg-blue-900 rounded-full">
              <div class="h-6 w-6 text-blue-600 dark:text-blue-300 i-hugeicons-upload-01"></div>
            </div>
            <div class="mt-3 sm:ml-4 sm:mt-0 text-center sm:text-left">
              <h3 class="font-semibold leading-6 text-base text-gray-900 dark:text-white">Import Subscribers</h3>
              <div class="mt-2">
                <p class="text-gray-500 text-sm dark:text-neutral-400">
                  Upload a CSV file with subscriber data to import into this list.
                </p>
              </div>
              <div class="mt-4">
                <div class="flex items-center justify-center w-full">
                  <label for="dropzone-file" class="flex flex-col items-center justify-center h-32 w-full bg-gray-50 dark:bg-neutral-700 hover:bg-gray-100 dark:hover:bg-neutral-700 border-2 border-dashed border-gray-300 rounded-lg dark:border-neutral-600 cursor-pointer">
                    <div class="flex flex-col items-center justify-center pb-6 pt-5">
                      <div class="mb-3 h-10 w-10 text-gray-400 dark:text-neutral-500 i-hugeicons-upload-01"></div>
                      <p class="mb-2 text-gray-500 text-sm dark:text-neutral-400"><span class="font-semibold">Click to upload</span> or drag and drop</p>
                      <p class="text-gray-500 text-xs dark:text-neutral-400">CSV file (MAX. 10MB)</p>
                    </div>
                    <input id="dropzone-file" type="file" class="hidden" accept=".csv" />
                  </label>
                </div>
                <div class="mt-4">
                  <p class="text-gray-500 text-xs dark:text-neutral-400">
                    Your CSV should include the following columns: email, phone (optional), first_name (optional), last_name (optional)
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="sm:flex sm:flex-row-reverse mt-5 sm:mt-4">
            <button
              type="button"
              class="inline-flex justify-center px-3 py-2 sm:ml-3 w-full sm:w-auto font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 rounded-md shadow-sm"
              onclick="importSubscribers(importListId || 0)"
            >
              Import
            </button>
            <button
              type="button"
              onclick="closeImportModal"
              class="inline-flex justify-center mt-3 px-3 py-2 sm:mt-0 w-full sm:w-auto font-semibold text-gray-900 text-sm dark:text-white bg-white dark:bg-neutral-700 hover:bg-gray-50 dark:hover:bg-neutral-600 ring-1 ring-gray-300 ring-inset rounded-md dark:ring-neutral-600 shadow-sm"
            >
              Cancel
            </button>
          </div>
        </div>
      </div>
    </div>
    @endif
  </main>

@endsection
