# Generated by `pantry container:generate` — native, depless container support.
# Build with: pantry build -t <name> .   (no Docker daemon required)
ARG BUN_VERSION=1.3.14
FROM oven/bun:${BUN_VERSION}-alpine AS base
WORKDIR /app

# Bring in the source (filtered by .freezer) and install deps in-image so
# the build context / release stays small.
COPY --chown=bun:bun . .
RUN bun install --frozen-lockfile --production

# Source and runtime dependencies are owned by the non-root runtime user.
USER bun

ENV APP_ENV=production
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000/tcp
CMD ["bun","storage/framework/core/buddy/src/cli.ts","serve"]
